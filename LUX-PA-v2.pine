
 
//@version=6

indicator("LUX-PA-v2", 'LUX-PA-v2', true, calc_bars_count = 2000, max_labels_count = 500, max_boxes_count = 500, max_lines_count = 500)

//---------------------------------------------------------------------------------------------------------------------
// Settings 
//---------------------------------------------------------------------------------------------------------------------{

display  = display.all - display.status_line

msGroup = 'Market Structures'
msShow = input.bool (true, 'Market Structures', group = msGroup)
msTerm = input.string('Intermediate Term', '  Detection', options = ['Micro', 'Short Term', 'Intermediate Term', 'Long Term', 'Macro'], group = msGroup)
msTextT = input.string('Enabled', '  Market Structure Labels', options = ['Enabled', 'Disabled'], group = msGroup, display = display), msText = msTextT == 'Enabled'
msLineStyle = input.string('Solid', '  Line Style', options = ['Solid', 'Dashed', 'Dotted'], group = msGroup, display = display)
msTriggerMode = input.string('Wick (Early)', '  Break Confirmation', options = ['Close (Confirmed)', 'Wick (Early)'], group = msGroup, display = display)
msCloseConfirmT = input.string('Enabled', '  Wick -> Close Confirm Gate', options = ['Enabled', 'Disabled'], group = msGroup, display = display), msCloseConfirm = msCloseConfirmT == 'Enabled'
msBullColor = input.color(#089981, '  Line Colors, Bullish', group = msGroup, inline = 'MS')
msBearColor = input.color(#f23645, 'Bearish', group = msGroup, inline = 'MS')

obbGroup = 'Order & Breaker Blocks'
obbShow = input.bool (true, 'Order & Breaker Blocks', group = obbGroup)
obbTerm = input.string('Long Term', '  Detection', options = ['Micro', 'Short Term', 'Intermediate Term', 'Long Term', 'Macro'], group = obbGroup, display = display)
obbBullLast = input.int(3, '  Last Bullish Blocks', minval = 0, group = obbGroup, display = display)
obbBearLast = input.int(3, '  Last Bearish Blocks', minval = 0, group = obbGroup, display = display)
obbUseBodyT = input.string('Enabled', '  Use Candle Body', options = ['Enabled', 'Disabled'], group = obbGroup, display = display), obbUseBody = obbUseBodyT == 'Enabled'
obbBullColor      = input(color.new(#089981, 73), '  Bullish OB '   , inline = 'bullC', group = obbGroup)
obbBullBreakColor = input(color.new(#f23645, 41), 'Bullish Break ', inline = 'bullC', group = obbGroup)
obbBearColor      = input(color.new(#f23645, 73), '  Bearish OB'   , inline = 'bearC', group = obbGroup)
obbBearBreakColor = input(color.new(#089981, 41), 'Bearish Break', inline = 'bearC', group = obbGroup)

liqGroup = 'Buyside & Sellside Liquidity'
liqBuySell = input.bool (true, 'Buyside & Sellside Liquidity', group = liqGroup)
liqTerm = input.string('Intermediate Term', '  Detection', options = ['Micro', 'Short Term', 'Intermediate Term', 'Long Term', 'Macro'], group = liqGroup)
liqMar = 10 / input.float (6.9, '  Margin', minval = 4, maxval = 9, step = 0.1, group = liqGroup, display = display)
cLIQ_B = input.color (#089981, '  Line Colors, Buyside', inline = 'LIQ', group = liqGroup)
cLIQ_S = input.color (#f23645, 'Sellside', inline = 'LIQ', group = liqGroup)
visLiq = input.int   (3, '  Visible Levels', minval = 1, maxval = 50, group = liqGroup, display = display)

liqGrp = 'Liquidity Voids'
lqVoid = input.bool (true, 'Liquidity Voids', group = liqGrp)
lqThresh = input.float(.75, '  Threshold Multiplier', minval = .05, step = .05, group = liqGrp, display = display)
lqMode  = input.string('Present', '  Mode', options =['Present', 'Historical'], inline = 'MD', group = liqGrp, display = display)
lqPeriod = input.int(360, ' ', inline = 'MD', group = liqGrp, display = display)
cLQV_B = input.color (#B2B5BE41, '  Bullish Zones', inline = 'void', group = liqGrp)
cLQV_S = input.color (#5D606B41, ' Bearish Zones', inline = 'void', group = liqGrp)
lqTextT = input.string('Disabled', '  Liquidity Void Labels', options = ['Enabled', 'Disabled'], group = liqGrp, display = display), lqText = lqTextT == 'Enabled'

swGroup = 'Swing Highs/Lows'
swShow = input.bool (true, 'Swing Highs/Lows', group = swGroup)
swTerm = input.string('Long Term', '  Detection', options = ['Micro', 'Short Term', 'Intermediate Term', 'Long Term', 'Macro'], group = swGroup)
swSwingsSZ  = input.string('Tiny', '  Label Size', options = ['Tiny', 'Small', 'Normal'], group = swGroup, display = display)
swBullColor = input.color(#089981, '  Label Colors, Bullish', group = swGroup, inline = 'MS')
swBearColor = input.color(#f23645, 'Bearish', group = swGroup, inline = 'MS')

dashGroup = 'Dashboard'
dashShow = input.bool(true, 'Show Lux-PA Panel', group = dashGroup, display = display)
dashPos = input.string('Top Right', 'Lux-PA Panel Position', options = ['Top Right', 'Top Left', 'Bottom Right', 'Bottom Left'], group = dashGroup, display = display)
dashEarlyShow = input.bool(true, 'Show EARLY Track Panel', group = dashGroup, display = display)
dashEarlyPos = input.string('Bottom Left', 'EARLY Track Position', options = ['Top Right', 'Top Left', 'Bottom Right', 'Bottom Left'], group = dashGroup, display = display)
dashNextMoveShow = input.bool(true, 'Show NEXT MOVE Panel', group = dashGroup, display = display)
dashNextMovePos = input.string('Bottom Right', 'NEXT MOVE Position', options = ['Top Right', 'Top Left', 'Bottom Right', 'Bottom Left'], group = dashGroup, display = display)
dashTargetConfluenceT = input.string('Strict (Macro+Micro)', '  Target Direction Filter', options = ['Loose', 'Strict (Macro+Micro)'], group = dashGroup, display = display)
dashTargetConfluence = dashTargetConfluenceT == 'Strict (Macro+Micro)'

sessGroup = 'Session Playbook'
sessEnable = input.bool(true, 'Session Playbook (6M Data)', group = sessGroup, display = display)
sessAsiaEnd = input.int(8, 'Asia End Hour (UTC)', minval = 1, maxval = 23, group = sessGroup, display = display)
sessLondonEnd = input.int(13, 'London End Hour (UTC)', minval = 2, maxval = 23, group = sessGroup, display = display)
sessNyEnd = input.int(22, 'NY End Hour (UTC)', minval = 3, maxval = 23, group = sessGroup, display = display)
sessCoilMax = input.float(70.0, 'Asia Coil Max ($)', minval = 10, step = 5, group = sessGroup, display = display, tooltip = '6M avg Asia range ~$79; tight coil < $70 → best playbook edge')
sessCoilAtrMult = input.float(6.0, 'Coil ATR Mult (0 = $ only)', minval = 0, step = 0.1, group = sessGroup, display = display, tooltip = 'Dual coil: tight if range ≤ $70 OR ≤ ATR×mult')
sessCoilDual = input.bool(true, 'Dual Coil ($ OR ATR)', group = sessGroup, display = display)
sessShowBox = input.bool(true, 'Show Asia Box (London/NY)', group = sessGroup, display = display)
sessShowAsiaSwings = input.bool(true, 'Mark Asia H/L at London Open', group = sessGroup, display = display)
sessFilterEarlyT = input.string('Hide Counter-Playbook', 'Early Signal Session Filter', options = ['Allow All', 'Hide Counter-Playbook', 'Playbook Only'], group = sessGroup, display = display)
sessMsGate = input.bool(true, 'Block Core MSS vs Playbook', group = sessGroup, display = display)
sessConfBoost = input.bool(true, 'Boost CONF on Playbook Align', group = sessGroup, display = display)
sessBearConfAdd = input.float(8.0, 'Bear Playbook CONF +', minval = 0, maxval = 20, step = 1, group = sessGroup, display = display)
sessBullConfAdd = input.float(5.0, 'Bull Playbook CONF +', minval = 0, maxval = 20, step = 1, group = sessGroup, display = display)

revGroup = 'Reversal Markers'
revShow = input.bool(true, 'Long-Term Reversal Markers', group = revGroup)
revSource = input.string('Long Term', '  Confirmed Source', options = ['Micro', 'Short Term', 'Intermediate Term', 'Long Term', 'Macro'], group = revGroup, display = display)
revMarkerSizeT = input.string('Normal', '  Marker Size', options = ['Tiny', 'Small', 'Normal', 'Large'], group = revGroup, display = display)
revEarlyShow = input.bool(true, '  Early Reversal Warnings', group = revGroup)
revEarlyTrendSource = input.string('Macro', '  Early Trend Source', options = ['Micro', 'Short Term', 'Intermediate Term', 'Long Term', 'Macro'], group = revGroup, display = display)
revEarlyTriggerSource = input.string('Micro', '  Early Trigger Source', options = ['Micro', 'Short Term', 'Intermediate Term', 'Long Term', 'Macro'], group = revGroup, display = display)
revEarlyIntentT = input.string('Trend Continuation', '  Early Signal Intent', options = ['Trend Continuation', 'Counter-Trend Reversal'], group = revGroup, display = display)
revEarlyModeT = input.string('Strict', '  Early Condition Mode', options = ['Strict', 'Balanced', 'Aggressive'], group = revGroup, display = display)
revEarlyMicroGate = input.bool(false, '  Require Micro Alignment', group = revGroup, display = display)
revEarlyRequireOppTrend = input.bool(true, '  Require Strict Trend Context', group = revGroup, display = display)
revEarlyRequireOppPrev = input.bool(true, '  Require Opposite Prior Trigger', group = revGroup, display = display)
revEarlyFlipLookbackBars = input.int(2, '  Flip Lookback Bars', minval = 0, group = revGroup, display = display)
revEarlyCooldownBars = input.int(8, '  Signal Cooldown Bars', minval = 0, group = revGroup, display = display)
revEarlyMinBodyAtr = input.float(0.10, '  Min Candle Body / ATR', minval = 0, step = 0.05, group = revGroup, display = display)
revEarlyAlignDirection = input.bool(true, '  Align Triangles to Direction', group = revGroup, display = display)
revEarlyDirectionSource = input.string('Micro', '  Direction Source', options = ['Micro', 'Macro', 'Trigger', 'Macro + Micro'], group = revGroup, display = display)
revEarlyCounterTrendT = input.string('Hide Counter-Trend', '  Counter-Trend Filter', options = ['Allow All', 'Sweep Only', 'Hide Counter-Trend'], group = revGroup, display = display)
revEarlyClusterBars = input.int(10, '  Cluster Cooldown (same dir)', minval = 0, group = revGroup, display = display)
revEarlyPingPongBars = input.int(8, '  Chop Block (opp dir)', minval = 0, group = revGroup, display = display)
revEarlyExceptionShow = input.bool(true, '  Allow Exception Counter-Trend Signals', group = revGroup, display = display)
revEarlyExceptionBodyAtr = input.float(0.35, '  Exception Min Body / ATR', minval = 0, step = 0.05, group = revGroup, display = display)
revEarlyExceptionCloseBreak = input.bool(false, '  Exception Require Close Break', group = revGroup, display = display)
revEarlyExceptionMicroGate = input.bool(false, '  Exception Require Micro Alignment', group = revGroup, display = display)
revEarlyExceptionOppPrev = input.bool(false, '  Exception Require Opposite Prior Trigger', group = revGroup, display = display)
revEarlyExceptionCooldownBars = input.int(8, '  Exception Cooldown Bars', minval = 0, group = revGroup, display = display)
revEarlyExceptionUseZoneContext = input.bool(true, '  Exception Use Zone Context', group = revGroup, display = display)
revEarlyExceptionInZoneBodyAtr = input.float(0.35, '  Exception In-Zone Min Body / ATR', minval = 0, step = 0.05, group = revGroup, display = display)
revEarlyExceptionOutZoneBodyAtr = input.float(0.77, '  Exception Out-of-Zone Min Body / ATR', minval = 0, step = 0.05, group = revGroup, display = display)
revEarlyExceptionAllowNearZone = input.bool(true, '  Exception Allow Near-Zone', group = revGroup, display = display)
revEarlyExceptionNearZoneAtr = input.float(0.25, '  Exception Near-Zone ATR Buffer', minval = 0, step = 0.05, group = revGroup, display = display)
revEarlySweepShow = input.bool(true, '  Allow Swing-Low SSL/BSL Reclaim', group = revGroup, display = display)
revEarlySweepRequireZone = input.bool(true, '  Reclaim Require OB or SSL Zone', group = revGroup, display = display)
revEarlySwingLookback = input.int(6, '  Swing Reclaim Window (bars)', minval = 1, maxval = 15, group = revGroup, display = display)
revEarlySweepBufferAtr = input.float(0.10, '  SSL/BSL Proximity (ATR)', minval = 0, step = 0.05, group = revGroup, display = display)
revEarlySwingMinBodyAtr = input.float(0.12, '  Swing Reclaim Min Body / ATR', minval = 0, step = 0.05, group = revGroup, display = display)
revEarlySweepRequireDisp = input.bool(true, '  Reclaim Require Close Break / Pop', group = revGroup, display = display)
revEarlySweepCooldownBars = input.int(12, '  Swing Reclaim Cooldown Bars', minval = 0, group = revGroup, display = display)
revTrackShow = input.bool(true, '  Track Early Quality', group = revGroup, display = display)
revTrackLookaheadBars = input.int(20, '  Track Lookahead Bars', minval = 1, group = revGroup, display = display)
revTrackAtrTarget = input.float(0.60, '  Track Target/Stop (ATR)', minval = 0.1, step = 0.05, group = revGroup, display = display)
nextMoveMinConf = input.int(52, '  Min Confidence Display', minval = 0, maxval = 100, group = revGroup, display = display)
revBullColor = input.color(color.new(#089981, 0), '  Bullish', inline = 'REV', group = revGroup)
revBearColor = input.color(color.new(#f23645, 0), 'Bearish', inline = 'REV', group = revGroup)

//---------------------------------------------------------------------------------------------------------------------}
// User Defined Types
//---------------------------------------------------------------------------------------------------------------------{

type BAR
    float   open  = open
    float   high  = high
    float   low   = low
    float   close = close
    int     index = bar_index

type ICTMS
    float   lastPrice
    float   midPrice
    float   prevPrice

    int     lastIndex
    int     midIndex
    int     prevIndex

    label   lastLabel
    label   midLabel
    label   prevLabel

    bool    isCrossed
    bool    isConfirmed

    int     marketStructure

    line    msLine
    label   msLabel
    box     swpBox

type MS
    int type = 0

type ZZ 
    int   [] d
    int   [] x 
    float [] y 

type liq
    box   bx
    box   bxz
    label bxt
    bool  brZ
    bool  brL
    line  ln
    line  lne
    int   anchorX = na

type ob
    float top = na
    float btm = na
    int   loc = bar_index
    bool  breaker = false
    int   break_loc = na

type SWING
    float y = na
    int   x = na
    bool  crossed = false

type vector
    array<SWING> v

type htfBar
    float price = na
    int   index = na

//---------------------------------------------------------------------------------------------------------------------}
// Generic Variables
//---------------------------------------------------------------------------------------------------------------------{

BAR bar = BAR.new()
var bxOBB = array.new_box()
var lnOBB = array.new_line()
var bullish_ob = array.new<ob>(0)
var bearish_ob = array.new<ob>(0)

var revPendDir = array.new_int()
var revPendEntry = array.new_float()
var revPendTp = array.new_float()
var revPendSl = array.new_float()
var revPendBorn = array.new_int()
var revPendExpiry = array.new_int()
var revPendMode = array.new_int() // 0 = core, 1 = exception

var int revBullTotal = 0
var int revBearTotal = 0
var int revBullCoreTotal = 0
var int revBearCoreTotal = 0
var int revBullExceptionTotal = 0
var int revBearExceptionTotal = 0
var int revBullWin = 0
var int revBearWin = 0
var int revBullFalse = 0
var int revBearFalse = 0
var int revBullTimeout = 0
var int revBearTimeout = 0
var int revCoreWin = 0
var int revCoreFalse = 0
var int revCoreTimeout = 0
var int revExceptionWin = 0
var int revExceptionFalse = 0
var int revExceptionTimeout = 0

var float sessAsiaHigh = na
var float sessAsiaLow = na
var int sessBreakSide = 0
var bool sessLondonHighBroken = false
var bool sessLondonLowBroken = false
var int sessAsiaBoxLeft = na
var box sessAsiaBoxDraw = na

//---------------------------------------------------------------------------------------------------------------------}
// Functions / Methods
//---------------------------------------------------------------------------------------------------------------------{

textSize(sizeInText) =>
    switch sizeInText
        'Tiny'   => size.tiny
        'Small'  => size.small
        'Normal' => size.normal
        => size.large

lineStyle(styleInText) =>
    switch styleInText
        'Solid'     => line.style_solid
        'Dotted'    => line.style_dotted
        'Dashed'    => line.style_dashed

dashPosition(posInText) =>
    switch posInText
        'Top Right' => position.top_right
        'Top Left' => position.top_left
        'Bottom Left' => position.bottom_left
        => position.bottom_right

dashRow(table t, int r, string k, string v, color vc) =>
    table.cell(t, 0, r, k, text_color = color.silver, text_size = size.tiny, bgcolor = color.new(color.black, 30), text_halign = text.align_left)
    table.cell(t, 1, r, v, text_color = vc, text_size = size.tiny, bgcolor = color.new(color.black, 60), text_halign = text.align_left)

dashRowAt(table t, int c0, int c1, int r, string k, string v, color vc) =>
    table.cell(t, c0, r, k, text_color = color.silver, text_size = size.tiny, bgcolor = color.new(color.black, 30), text_halign = text.align_left)
    table.cell(t, c1, r, v, text_color = vc, text_size = size.tiny, bgcolor = color.new(color.black, 60), text_halign = text.align_left)

sessHourUtc() =>
    hour(time, 'UTC')

sessInAsia(int endHr) =>
    h = sessHourUtc()
    h >= 0 and h < endHr

sessInLondon(int asiaEnd, int londonEnd) =>
    h = sessHourUtc()
    h >= asiaEnd and h < londonEnd

sessInNy(int londonEnd, int nyEnd) =>
    h = sessHourUtc()
    h >= londonEnd and h < nyEnd

ratioPctStr(int wins, int losses) =>
    total = wins + losses
    total > 0 ? str.tostring((wins * 100.0) / total, '#.0') + '%' : 'N/A'

timeframe(userTimeframe) =>
    float chartTFinM = timeframe.in_seconds() / 60

    switch 
        userTimeframe == "Auto"       and chartTFinM <= 60   => 'D'
        userTimeframe == "Auto"       and chartTFinM <= 1440 => 'W'
        userTimeframe == "5 Minutes"  and chartTFinM <= 5    => '5'
        userTimeframe == "15 Minutes" and chartTFinM <= 15   => '15'
        userTimeframe == "1 Hour"     and chartTFinM <= 60   => '60'
        userTimeframe == "4 Hours"    and chartTFinM <= 240  => '240'
        userTimeframe == "1 Day"      and timeframe.isintraday => 'D'
        (userTimeframe == "Auto" or userTimeframe == "1 Week")  and (timeframe.isdaily or timeframe.isintraday) => 'W'
        (userTimeframe == "Auto" or userTimeframe == "1 Month") and (timeframe.isweekly or timeframe.isdaily or timeframe.isintraday) => 'M'
        => timeframe.period

queryPatterns(lastPrice, midPrice, prevPrice, isSwingHigh) =>
    if isSwingHigh
        prevPrice < midPrice and midPrice >= lastPrice
    else
        prevPrice > midPrice and midPrice <= lastPrice

method queryPatterns(ICTMS this, isSwingHigh) =>
    if isSwingHigh
        this.prevPrice < this.midPrice and this.midPrice >= this.lastPrice
    else
        this.prevPrice > this.midPrice and this.midPrice <= this.lastPrice

method updatePattern(ICTMS this, price, index) =>
    this.isCrossed := false
    this.isConfirmed := false
    // Delete label handle that is about to roll out of the 3-point chain.
    if not na(this.prevLabel)
        label.delete(this.prevLabel)
    this.prevPrice := this.midPrice, this.midPrice := this.lastPrice, this.lastPrice := price
    this.prevIndex := this.midIndex, this.midIndex := this.lastIndex, this.lastIndex := index
    this.prevLabel := this.midLabel, this.midLabel := this.lastLabel

method setType(MS this, value) =>
    this.type := value

method renderStructures(ICTMS this, isBullish, marketStructure, color, style, labelEnabled, drawEnabled) =>

    wickCondition = isBullish ? bar.high > this.lastPrice : bar.low < this.lastPrice
    closeCondition = isBullish ? bar.close > this.lastPrice : bar.close < this.lastPrice
    useWick = msTriggerMode == 'Wick (Early)'
    wasConfirmed = this.isConfirmed

    if useWick and wickCondition and not this.isCrossed
        this.isCrossed := true
        this.isConfirmed := not msCloseConfirm

    if not useWick and closeCondition and not this.isCrossed
        this.isCrossed := true
        this.isConfirmed := true

    if useWick and this.isCrossed and not this.isConfirmed and closeCondition
        this.isConfirmed := true

    // Render only on the confirmation transition (false -> true).
    if this.isCrossed and this.isConfirmed and not wasConfirmed
        if drawEnabled
            this.msLine := line.new(this.lastIndex, this.lastPrice, bar.index, this.lastPrice, color = color, style = lineStyle(style))
            this.swpBox := box.new(bar.index, this.lastPrice, bar.index, this.lastPrice, color.new(color, 73), bgcolor = color.new(color, 73))

            if labelEnabled
                msMidX = int(math.round((this.lastIndex + bar.index) / 2))
                msLabelText = marketStructure.type == (isBullish ? -1 : 1) ? 'MSS' : 'BOS'
                msLabelTextColor = isBullish ? color.new(msBullColor, 0) : color.new(msBearColor, 0)
                // Keep MSS/BOS text clearly away from structure lines even when zoomed out.
                msLabelYOffset = math.max(ta.atr(14) * 0.35, syminfo.mintick * 120)
                msLabelY = this.lastPrice + (isBullish ? msLabelYOffset : -msLabelYOffset)
                this.msLabel := label.new(msMidX, msLabelY, msLabelText, xloc = xloc.bar_index, yloc = yloc.price, style = label.style_none, textcolor = msLabelTextColor, size = size.small)

        marketStructure.setType(isBullish ? 1 : -1)

method in_out(ZZ aZZ, int _d, int _x, float _y) =>
    aZZ.d.unshift(_d), aZZ.x.unshift(_x), aZZ.y.unshift(_y), aZZ.d.pop(), aZZ.x.pop(), aZZ.y.pop()

method detectSwings(array<vector> id, mode, depth)=>
    var SWING swingLevel = SWING.new(na, na)
    for i = 0 to depth - 1
        get_v = id.get(i).v

        if get_v.size() == 3
            pivot = switch mode
                'bull' => math.max(get_v.get(0).y, get_v.get(1).y, get_v.get(2).y)
                'bear' => math.min(get_v.get(0).y, get_v.get(1).y, get_v.get(2).y)

            if pivot == get_v.get(1).y
                if i < depth - 1
                    id.get(i+1).v.unshift(get_v.get(1))

                    if id.get(i+1).v.size() > 3
                        id.get(i+1).v.pop()
                else
                    swingLevel := SWING.new(get_v.get(1).y, get_v.get(1).x)
            
                get_v.pop()
                get_v.pop()
    swingLevel

method renderBlocks(ob id, color, breakColor, bbText, bbTextColor)=>
    avg = math.avg(id.top, id.btm)

    if id.breaker
        bxOBB.push(box.new(id.loc, id.top, id.break_loc, id.btm, color, bgcolor = color, xloc = xloc.bar_time, text = bbText, text_color = bbTextColor, text_size = size.small, text_halign = text.align_center, text_valign = text.align_center))
        lnOBB.push(line.new(id.break_loc, id.top, timenow, id.top, xloc.bar_time, extend.none, breakColor))
        lnOBB.push(line.new(id.break_loc, id.btm, timenow, id.btm, xloc.bar_time, extend.none, breakColor))
        lnOBB.push(line.new(id.loc, avg, timenow, avg, xloc.bar_time, extend.none, breakColor, style = line.style_dotted))
    
    if not id.breaker
        bxOBB.push(box.new(id.loc, id.top, timenow, id.btm, na, bgcolor = color, extend = extend.none, xloc = xloc.bar_time))
        lnOBB.push(line.new(id.loc, id.top, timenow, id.top, xloc.bar_time, extend.none, color))
        lnOBB.push(line.new(id.loc, id.btm, timenow, id.btm, xloc.bar_time, extend.none, color))
        lnOBB.push(line.new(id.loc, avg, timenow, avg, xloc.bar_time, extend.none, breakColor, style = line.style_dotted))

//---------------------------------------------------------------------------------------------------------------------}
// Calculations - Session Playbook (6M: coil → London break → NY expansion)
//---------------------------------------------------------------------------------------------------------------------{

inAsiaSess = sessEnable and sessInAsia(sessAsiaEnd)
inLondonSess = sessEnable and sessInLondon(sessAsiaEnd, sessLondonEnd)
inNySess = sessEnable and sessInNy(sessLondonEnd, sessNyEnd)
asiaSessOpen = inAsiaSess and not inAsiaSess[1]
londonSessOpen = inLondonSess and not inLondonSess[1]

if sessEnable
    if asiaSessOpen
        sessAsiaHigh := high
        sessAsiaLow := low
        sessBreakSide := 0
        sessLondonHighBroken := false
        sessLondonLowBroken := false
        sessAsiaBoxLeft := bar_index
        if not na(sessAsiaBoxDraw)
            box.delete(sessAsiaBoxDraw)
            sessAsiaBoxDraw := na
    else if inAsiaSess
        sessAsiaHigh := math.max(nz(sessAsiaHigh, high), high)
        sessAsiaLow := math.min(nz(sessAsiaLow, low), low)
    if inLondonSess or inNySess
        if not na(sessAsiaHigh) and high > sessAsiaHigh
            sessLondonHighBroken := true
            if sessBreakSide == 0
                sessBreakSide := 1
        if not na(sessAsiaLow) and low < sessAsiaLow
            sessLondonLowBroken := true
            if sessBreakSide == 0
                sessBreakSide := -1

sessAtrEarly = ta.atr(14)
sessAsiaRange = sessEnable and not na(sessAsiaHigh) and not na(sessAsiaLow) ? sessAsiaHigh - sessAsiaLow : na
sessCoilTightUsd = not na(sessAsiaRange) and sessAsiaRange <= sessCoilMax
sessCoilTightAtr = sessCoilAtrMult > 0 and not na(sessAsiaRange) and sessAsiaRange <= sessAtrEarly * sessCoilAtrMult
sessCoilActive = sessEnable and not na(sessAsiaRange) and sessAsiaRange > 0 and (sessCoilDual ? (sessCoilTightUsd or sessCoilTightAtr) : sessCoilTightUsd)
sessPlaybookBull = sessCoilActive and sessBreakSide == 1
sessPlaybookBear = sessCoilActive and sessBreakSide == -1
sessPlaybookReady = sessCoilActive and sessBreakSide != 0
sessExpansionWindow = sessPlaybookReady and (inLondonSess or inNySess)
sessNyExpansion = sessPlaybookReady and inNySess
sessAsiaSsl = sessEnable and not inAsiaSess and not na(sessAsiaLow) ? sessAsiaLow : na
sessAsiaBsl = sessEnable and not inAsiaSess and not na(sessAsiaHigh) ? sessAsiaHigh : na
sessEdgeBuf = sessAtrEarly * revEarlySweepBufferAtr
bullAsiaEdgeZone = sessEnable and sessAtrEarly > 0 and not na(sessAsiaLow) and (inLondonSess or inNySess) and low <= sessAsiaLow + sessEdgeBuf and close >= sessAsiaLow - sessEdgeBuf
bearAsiaEdgeZone = sessEnable and sessAtrEarly > 0 and not na(sessAsiaHigh) and (inLondonSess or inNySess) and high >= sessAsiaHigh - sessEdgeBuf and close <= sessAsiaHigh + sessEdgeBuf

//---------------------------------------------------------------------------------------------------------------------}
// Calculations - Swings 
//---------------------------------------------------------------------------------------------------------------------{

var ICTMS stLow  = ICTMS.new()
var ICTMS stHigh = ICTMS.new()
var MS stMS = MS.new()

drawMicro = msShow and (msTerm == 'Micro' or msTerm == 'Short Term')
drawIntermediate = msShow and msTerm == 'Intermediate Term'
drawLong = msShow and msTerm == 'Long Term'
drawMacro = msShow and msTerm == 'Macro'

// Evaluate breaks on current levels before any swing roll/update happens on this bar.
stLow.renderStructures(false, stMS, msBearColor, msLineStyle, msText, drawMicro)
stHigh.renderStructures(true, stMS, msBullColor, msLineStyle, msText, drawMicro)

if bar_index >= 2 and queryPatterns(bar.low, (bar[1]).low, (bar[2]).low, false)
    stLow.updatePattern((bar[1]).low, (bar[1]).index)
    stLow.lastLabel := label.new(stLow.lastIndex, stLow.lastPrice, '⦁', color = color(na), textcolor = swShow and (swTerm == 'Micro' or swTerm == 'Short Term') ? swBearColor : color(na), style = label.style_label_up, size = textSize(swSwingsSZ), tooltip = str.tostring(stLow.lastPrice, format.mintick))

if bar_index >= 2 and queryPatterns(bar.high, (bar[1]).high, (bar[2]).high, true)
    stHigh.updatePattern((bar[1]).high, (bar[1]).index)
    stHigh.lastLabel := label.new((bar[1]).index, (bar[1]).high, '⦁', color = color(na), textcolor = swShow and (swTerm == 'Micro' or swTerm == 'Short Term') ? swBullColor : color(na), style = label.style_label_down, size = textSize(swSwingsSZ), tooltip = str.tostring((bar[1]).high, format.mintick))

var ICTMS itLow  = ICTMS.new()
var ICTMS itHigh = ICTMS.new()
var MS itMS = MS.new()

itLow.renderStructures(false, itMS, msBearColor, msLineStyle, msText, drawIntermediate)
itHigh.renderStructures(true, itMS, msBullColor, msLineStyle, msText, drawIntermediate)

cITL = stLow.queryPatterns(false) 

if cITL and cITL != cITL[1]
    itLow.updatePattern(stLow.midPrice, stLow.midIndex)

    itLow.lastLabel := stLow.midLabel

    if swShow and swTerm == 'Intermediate Term'
        stLow.midLabel.set_size(textSize(swSwingsSZ))
        stLow.midLabel.set_textcolor(swBearColor)

cITH = stHigh.queryPatterns(true) 

if cITH and cITH != cITH[1]
    itHigh.updatePattern(stHigh.midPrice, stHigh.midIndex)

    itHigh.lastLabel := stHigh.midLabel

    if swShow and swTerm == 'Intermediate Term'
        stHigh.midLabel.set_size(textSize(swSwingsSZ))
        stHigh.midLabel.set_textcolor(swBullColor)

var ICTMS ltLow  = ICTMS.new()
var ICTMS ltHigh = ICTMS.new()
var MS ltMS = MS.new()

ltLow.renderStructures(false, ltMS, msBearColor, msLineStyle, msText, drawLong)
ltHigh.renderStructures(true, ltMS, msBullColor, msLineStyle, msText, drawLong)

cLTL = itLow.queryPatterns(false)

if cLTL and cLTL != cLTL[1]
    ltLow.updatePattern(itLow.midPrice, itLow.midIndex)

    if swShow and swTerm == 'Long Term'
        itLow.midLabel.set_size(textSize(swSwingsSZ))
        itLow.midLabel.set_textcolor(swBearColor)

cLTH = itHigh.queryPatterns(true)

if cLTH and cLTH != cLTH[1]
    ltHigh.updatePattern(itHigh.midPrice, itHigh.midIndex)

    if swShow and swTerm == 'Long Term'
        itHigh.midLabel.set_size(textSize(swSwingsSZ))
        itHigh.midLabel.set_textcolor(swBullColor)

var ICTMS mcLow  = ICTMS.new()
var ICTMS mcHigh = ICTMS.new()
var MS mcMS = MS.new()

mcLow.renderStructures(false, mcMS, msBearColor, msLineStyle, msText, drawMacro)
mcHigh.renderStructures(true, mcMS, msBullColor, msLineStyle, msText, drawMacro)

cMCL = ltLow.queryPatterns(false)

if cMCL and cMCL != cMCL[1]
    mcLow.updatePattern(ltLow.midPrice, ltLow.midIndex)

    if swShow and swTerm == 'Macro'
        ltLow.midLabel.set_size(textSize(swSwingsSZ))
        ltLow.midLabel.set_textcolor(swBearColor)

cMCH = ltHigh.queryPatterns(true)

if cMCH and cMCH != cMCH[1]
    mcHigh.updatePattern(ltHigh.midPrice, ltHigh.midIndex)

    if swShow and swTerm == 'Macro'
        ltHigh.midLabel.set_size(textSize(swSwingsSZ))
        ltHigh.midLabel.set_textcolor(swBullColor)

//---------------------------------------------------------------------------------------------------------------------}
// Session visuals (Asia box + swing labels)
//---------------------------------------------------------------------------------------------------------------------{

if sessShowBox and sessEnable and (inLondonSess or inNySess) and not na(sessAsiaHigh) and not na(sessAsiaLow) and not na(sessAsiaBoxLeft)
    coilCol = color.new(color.orange, 85)
    if na(sessAsiaBoxDraw)
        sessAsiaBoxDraw := box.new(sessAsiaBoxLeft, sessAsiaHigh, bar.index, sessAsiaLow, border_color = color.new(color.orange, 40), bgcolor = coilCol, border_width = 1)
    else
        box.set_right(sessAsiaBoxDraw, bar.index)
        box.set_top(sessAsiaBoxDraw, sessAsiaHigh)
        box.set_bottom(sessAsiaBoxDraw, sessAsiaLow)

if sessShowAsiaSwings and londonSessOpen and not na(sessAsiaHigh) and not na(sessAsiaLow)
    label.new(bar.index, sessAsiaHigh, 'Asia H', xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_down, color = color(na), textcolor = color.new(#089981, 0), size = size.tiny)
    label.new(bar.index, sessAsiaLow, 'Asia L', xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_up, color = color(na), textcolor = color.new(#f23645, 0), size = size.tiny)

//---------------------------------------------------------------------------------------------------------------------}
// Calculations - Market Structures 
//---------------------------------------------------------------------------------------------------------------------{

// (Structure rendering moved earlier, before swing updates, to avoid missing same-bar reversals.)

// Long-term regime flip markers (major direction changes).
revType = switch revSource
    'Micro' => stMS.type
    'Short Term' => stMS.type
    'Intermediate Term' => itMS.type
    'Long Term' => ltMS.type
    => mcMS.type

var int stTypePrev = 0
var int itTypePrev = 0
var int ltTypePrev = 0
var int mcTypePrev = 0
var int bullEarlyLastBar = na
var int bearEarlyLastBar = na
var int bullExceptionLastBar = na
var int bearExceptionLastBar = na
var int bullFlipBar = na
var int bearFlipBar = na
var int bullFlipSignaled = na
var int bearFlipSignaled = na
var int bullSweepLastBar = na
var int bearSweepLastBar = na
var int revEarlyLastBullPlotBar = na
var int revEarlyLastBearPlotBar = na
var int bullSwingBar = na
var float bullSwingPrice = na
var float bullSwingSsl = na
var int bearSwingBar = na
var float bearSwingPrice = na
var float bearSwingBsl = na
var bool bullSweepCoreHit = false
var bool bullSweepExcHit = false
var bool bearSweepCoreHit = false
var bool bearSweepExcHit = false

revTypePrev = switch revSource
    'Micro' => stTypePrev
    'Short Term' => stTypePrev
    'Intermediate Term' => itTypePrev
    'Long Term' => ltTypePrev
    => mcTypePrev

bullReversal = revShow and revType == 1 and revTypePrev != 1
bearReversal = revShow and revType == -1 and revTypePrev != -1

revEarlyTrendType = switch revEarlyTrendSource
    'Micro' => stMS.type
    'Short Term' => stMS.type
    'Intermediate Term' => itMS.type
    'Long Term' => ltMS.type
    => mcMS.type

revEarlyTriggerType = switch revEarlyTriggerSource
    'Micro' => stMS.type
    'Short Term' => stMS.type
    'Intermediate Term' => itMS.type
    'Long Term' => ltMS.type
    => mcMS.type

revEarlyTriggerPrev = switch revEarlyTriggerSource
    'Micro' => stTypePrev
    'Short Term' => stTypePrev
    'Intermediate Term' => itTypePrev
    'Long Term' => ltTypePrev
    => mcTypePrev

revEarlyContinuation = revEarlyIntentT == 'Trend Continuation'
bullFlipEvent = revEarlyTriggerType == 1 and revEarlyTriggerPrev == -1
bearFlipEvent = revEarlyTriggerType == -1 and revEarlyTriggerPrev == 1
if bullFlipEvent
    bullFlipBar := bar.index
    bullFlipSignaled := na
if bearFlipEvent
    bearFlipBar := bar.index
    bearFlipSignaled := na
bullFlipWindow = revEarlyTriggerType == 1 and not na(bullFlipBar) and bar.index - bullFlipBar <= revEarlyFlipLookbackBars
bearFlipWindow = revEarlyTriggerType == -1 and not na(bearFlipBar) and bar.index - bearFlipBar <= revEarlyFlipLookbackBars
bullFlipFreshOk = na(bullFlipSignaled) or bullFlipSignaled != bullFlipBar
bearFlipFreshOk = na(bearFlipSignaled) or bearFlipSignaled != bearFlipBar
bullTrendStrict = revEarlyContinuation ? revEarlyTrendType == 1 : revEarlyTrendType == -1
bearTrendStrict = revEarlyContinuation ? revEarlyTrendType == -1 : revEarlyTrendType == 1
bullTrendLoose = revEarlyContinuation ? revEarlyTrendType != -1 : revEarlyTrendType != 1
bearTrendLoose = revEarlyContinuation ? revEarlyTrendType != 1 : revEarlyTrendType != -1
bullTrendBalancedOk = revEarlyRequireOppTrend ? bullTrendStrict : bullTrendLoose
bearTrendBalancedOk = revEarlyRequireOppTrend ? bearTrendStrict : bearTrendLoose
bullTrendAggressiveOk = revEarlyRequireOppTrend ? bullTrendStrict : true
bearTrendAggressiveOk = revEarlyRequireOppTrend ? bearTrendStrict : true
bullTriggerFlipOk = revEarlyRequireOppPrev ? bullFlipEvent or (revEarlyFlipLookbackBars > 0 and bullFlipWindow) : revEarlyTriggerPrev != 1
bearTriggerFlipOk = revEarlyRequireOppPrev ? bearFlipEvent or (revEarlyFlipLookbackBars > 0 and bearFlipWindow) : revEarlyTriggerPrev != -1

bullEarlyStrict = bullTrendStrict and revEarlyTriggerType == 1 and bullTriggerFlipOk and bullFlipFreshOk
bearEarlyStrict = bearTrendStrict and revEarlyTriggerType == -1 and bearTriggerFlipOk and bearFlipFreshOk
bullEarlyBalanced = bullTrendBalancedOk and revEarlyTriggerType == 1 and bullTriggerFlipOk and bullFlipFreshOk
bearEarlyBalanced = bearTrendBalancedOk and revEarlyTriggerType == -1 and bearTriggerFlipOk and bearFlipFreshOk
bullEarlyAggressive = bullTrendAggressiveOk and revEarlyTriggerType == 1 and bullTriggerFlipOk and bullFlipFreshOk
bearEarlyAggressive = bearTrendAggressiveOk and revEarlyTriggerType == -1 and bearTriggerFlipOk and bearFlipFreshOk

bullEarlyMode = switch revEarlyModeT
    'Strict' => bullEarlyStrict
    'Balanced' => bullEarlyBalanced
    => bullEarlyAggressive

bearEarlyMode = switch revEarlyModeT
    'Strict' => bearEarlyStrict
    'Balanced' => bearEarlyBalanced
    => bearEarlyAggressive

revEarlyBody = math.abs(close - open)
revEarlyAtr = ta.atr(14)
revEarlyBodyAtrRatio = revEarlyAtr > 0 ? revEarlyBody / revEarlyAtr : 0
revEarlyBodyOk = revEarlyBodyAtrRatio >= revEarlyMinBodyAtr

bullEarlyCore = revEarlyShow and bullEarlyMode and revEarlyBodyOk
bearEarlyCore = revEarlyShow and bearEarlyMode and revEarlyBodyOk
bullEarlyCoreGated = bullEarlyCore and (not revEarlyMicroGate or stMS.type == 1)
bearEarlyCoreGated = bearEarlyCore and (not revEarlyMicroGate or stMS.type == -1)
sessBlockBullCore = sessEnable and sessMsGate and sessExpansionWindow and sessPlaybookBear
sessBlockBearCore = sessEnable and sessMsGate and sessExpansionWindow and sessPlaybookBull
bullEarlyCoreGated := bullEarlyCoreGated and not sessBlockBullCore
bearEarlyCoreGated := bearEarlyCoreGated and not sessBlockBearCore

// Exception layer: allow selective opposite-trend EARLY signals on strong impulse reversals.
bullExceptionTrend = revEarlyContinuation and revEarlyTrendType == -1
bearExceptionTrend = revEarlyContinuation and revEarlyTrendType == 1
revInBullZone = false
revInBearZone = false
revBullZoneDist = 10e6
revBearZoneDist = 10e6

if bullish_ob.size() > 0
    for i = 0 to bullish_ob.size() - 1
        z = bullish_ob.get(i)
        zDist = close < z.btm ? z.btm - close : close > z.top ? close - z.top : 0
        revBullZoneDist := math.min(revBullZoneDist, zDist)
        if close <= z.top and close >= z.btm
            revInBullZone := true
            break

if bearish_ob.size() > 0
    for i = 0 to bearish_ob.size() - 1
        z = bearish_ob.get(i)
        zDist = close < z.btm ? z.btm - close : close > z.top ? close - z.top : 0
        revBearZoneDist := math.min(revBearZoneDist, zDist)
        if close <= z.top and close >= z.btm
            revInBearZone := true
            break

bullNearZone = revEarlyExceptionAllowNearZone and revEarlyAtr > 0 and revBullZoneDist <= revEarlyAtr * revEarlyExceptionNearZoneAtr
bearNearZone = revEarlyExceptionAllowNearZone and revEarlyAtr > 0 and revBearZoneDist <= revEarlyAtr * revEarlyExceptionNearZoneAtr
bullZoneContextOk = revInBullZone or bullNearZone or bullAsiaEdgeZone
bearZoneContextOk = revInBearZone or bearNearZone or bearAsiaEdgeZone

bullExceptionRequiredBodyAtr = revEarlyExceptionUseZoneContext ? (bullZoneContextOk ? revEarlyExceptionInZoneBodyAtr : revEarlyExceptionOutZoneBodyAtr) : revEarlyExceptionBodyAtr
bearExceptionRequiredBodyAtr = revEarlyExceptionUseZoneContext ? (bearZoneContextOk ? revEarlyExceptionInZoneBodyAtr : revEarlyExceptionOutZoneBodyAtr) : revEarlyExceptionBodyAtr
bullExceptionBodyOk = revEarlyBodyAtrRatio >= bullExceptionRequiredBodyAtr
bearExceptionBodyOk = revEarlyBodyAtrRatio >= bearExceptionRequiredBodyAtr
bullExceptionCloseBreakOk = not revEarlyExceptionCloseBreak or close > high[1]
bearExceptionCloseBreakOk = not revEarlyExceptionCloseBreak or close < low[1]
bullExceptionFlipOk = revEarlyExceptionOppPrev ? bullTriggerFlipOk : revEarlyTriggerPrev != 1
bearExceptionFlipOk = revEarlyExceptionOppPrev ? bearTriggerFlipOk : revEarlyTriggerPrev != -1
bullExceptionMicroOk = not revEarlyExceptionMicroGate or stMS.type == 1
bearExceptionMicroOk = not revEarlyExceptionMicroGate or stMS.type == -1
bullExceptionZoneOk = not revEarlyExceptionUseZoneContext or bullZoneContextOk
bearExceptionZoneOk = not revEarlyExceptionUseZoneContext or bearZoneContextOk
bullException = revEarlyShow and revEarlyExceptionShow and bullExceptionTrend and bullExceptionZoneOk and revEarlyTriggerType == 1 and bullExceptionFlipOk and bullExceptionBodyOk and bullExceptionCloseBreakOk and bullExceptionMicroOk
bearException = revEarlyShow and revEarlyExceptionShow and bearExceptionTrend and bearExceptionZoneOk and revEarlyTriggerType == -1 and bearExceptionFlipOk and bearExceptionBodyOk and bearExceptionCloseBreakOk and bearExceptionMicroOk

bullEarlyCoreCooldownOk = revEarlyCooldownBars <= 0 or na(bullEarlyLastBar) or bar.index - bullEarlyLastBar > revEarlyCooldownBars
bearEarlyCoreCooldownOk = revEarlyCooldownBars <= 0 or na(bearEarlyLastBar) or bar.index - bearEarlyLastBar > revEarlyCooldownBars
bullExceptionCooldownOk = revEarlyExceptionCooldownBars <= 0 or na(bullExceptionLastBar) or bar.index - bullExceptionLastBar > revEarlyExceptionCooldownBars
bearExceptionCooldownOk = revEarlyExceptionCooldownBars <= 0 or na(bearExceptionLastBar) or bar.index - bearExceptionLastBar > revEarlyExceptionCooldownBars
bullEarlyCoreBase = bullEarlyCoreGated and bullEarlyCoreCooldownOk
bearEarlyCoreBase = bearEarlyCoreGated and bearEarlyCoreCooldownOk
bullExceptionBase = bullException and bullExceptionCooldownOk
bearExceptionBase = bearException and bearExceptionCooldownOk
bullEarlyCoreFinal = bullEarlyCoreBase
bearEarlyCoreFinal = bearEarlyCoreBase
bullExceptionFinal = bullExceptionBase
bearExceptionFinal = bearExceptionBase
bullEarlyStruct = false
bearEarlyStruct = false
bullEarly = false
bearEarly = false

//---------------------------------------------------------------------------------------------------------------------}
// Calculations - Buyside & Sellside Liquidity
//---------------------------------------------------------------------------------------------------------------------{

maxSize = 50
atr     = ta.atr(10)

var ZZ aZZ = ZZ.new(
 array.new <int>  (maxSize,  0), 
 array.new <int>  (maxSize,  0), 
 array.new <float>(maxSize, na)
 )


var liq[] b_liq_B = array.new<liq> (1, liq.new(box(na), box(na), label(na), false, false, line(na), line(na), na))
var liq[] b_liq_S = array.new<liq> (1, liq.new(box(na), box(na), label(na), false, false, line(na), line(na), na))

var b_liq_V = array.new_box()

var int dir = na, var int x1 = na, var float y1 = na, var int x2 = na, var float y2 = na

[topLQ, btmLQ]  = switch liqTerm
    'Micro' => [SWING.new(stHigh.lastPrice, stHigh.lastIndex), SWING.new(stLow.lastPrice, stLow.lastIndex)]
    'Short Term' => [SWING.new(stHigh.lastPrice, stHigh.lastIndex), SWING.new(stLow.lastPrice, stLow.lastIndex)]
    'Intermediate Term' =>  [SWING.new(itHigh.lastPrice, itHigh.lastIndex), SWING.new(itLow.lastPrice, itLow.lastIndex)]
    'Long Term' =>  [SWING.new(ltHigh.lastPrice, ltHigh.lastIndex), SWING.new(ltLow.lastPrice, ltLow.lastIndex)]
    'Macro' =>  [SWING.new(mcHigh.lastPrice, mcHigh.lastIndex), SWING.new(mcLow.lastPrice, mcLow.lastIndex)]

if not liqBuySell
    topLQ := SWING.new(0, 0)
    btmLQ := SWING.new(0, 0)

swingHigh = topLQ.y 
swingLow  = btmLQ.y 

x2 := bar.index - 1

if swingHigh > 0 and swingHigh != swingHigh[1]   
    dir := aZZ.d.get(0) 
    x1  := aZZ.x.get(0)
    x2  := topLQ.x
    y1  := aZZ.y.get(0) 
    y2  := swingHigh//nz(bar.high[1])

    if dir < 1
        aZZ.in_out(1, x2, y2)
    else
        if dir == 1 and swingHigh > y1 
            aZZ.x.set(0, x2), aZZ.y.set(0, y2)
    
    if true
        count = 0
        st_P  = 0.
        st_B  = 0
        minP  = 0.
        maxP  = 10e6

        for i = 0 to maxSize - 1
            if aZZ.d.get(i) ==  1 
                if aZZ.y.get(i) > swingHigh + (atr / liqMar)
                    break
                else
                    if aZZ.y.get(i) > swingHigh - (atr / liqMar) and aZZ.y.get(i) < swingHigh + (atr / liqMar)
                        count += 1
                        st_B := aZZ.x.get(i)
                        st_P := aZZ.y.get(i)
                        if aZZ.y.get(i) > minP
                            minP := aZZ.y.get(i)
                        if aZZ.y.get(i) < maxP 
                            maxP := aZZ.y.get(i)

        if count > 2
            getB = b_liq_B.get(0)

            if st_B == getB.bx.get_left()
                getB.bx.set_top(math.avg(minP, maxP) + (atr / liqMar))
                getB.bx.set_rightbottom(bar.index + 10, math.avg(minP, maxP) - (atr / liqMar))
            else
                b_liq_B.unshift(
                 liq.new(
                   box.new(st_B, math.avg(minP, maxP) + (atr / liqMar), bar.index + 10, math.avg(minP, maxP) - (atr / liqMar), bgcolor=color(na), border_color=color(na)), 
                   box.new(na, na, na, na, bgcolor = color(na), border_color = color(na)),
                   label.new(st_B, st_P, 'Buyside liquidity', xloc = xloc.bar_index, yloc = yloc.price, style = label.style_none, textcolor = color.new(#089981, 0), size = size.small),
                   false, 
                   false,
                   line.new(st_B   , st_P, bar.index - 1, st_P, color = color.new(cLIQ_B, 0)),
                   line.new(bar.index - 1, st_P, na     , st_P, color = color.new(cLIQ_B, 0), style = line.style_dotted),
                   st_B)
                 )

            if b_liq_B.size() > visLiq
                getLast = b_liq_B.pop()
                getLast.bx.delete()
                getLast.bxz.delete()
                label.delete(getLast.bxt)
                getLast.ln.delete()
                getLast.lne.delete()               

if swingLow > 0 and swingLow != swingLow[1]
    dir := aZZ.d.get (0) 
    x1  := aZZ.x.get (0) 
    x2  := btmLQ.x
    y1  := aZZ.y.get (0) 
    y2  := swingLow//nz(bar.low[1])
    
    if dir > -1
        aZZ.in_out(-1, x2, y2)
    else
        if dir == -1 and swingLow < y1 
            aZZ.x.set(0, x2), aZZ.y.set(0, y2)
    
    if true
        count = 0
        st_P  = 0.
        st_B  = 0
        minP  = 0.
        maxP  = 10e6

        for i = 0 to maxSize - 1
            if aZZ.d.get(i) == -1 
                if aZZ.y.get(i) < swingLow - (atr / liqMar)
                    break
                else
                    if aZZ.y.get(i) > swingLow - (atr / liqMar) and aZZ.y.get(i) < swingLow + (atr / liqMar)
                        count += 1
                        st_B := aZZ.x.get(i)
                        st_P := aZZ.y.get(i)
                        if aZZ.y.get(i) > minP
                            minP := aZZ.y.get(i)
                        if aZZ.y.get(i) < maxP 
                            maxP := aZZ.y.get(i)

        if count > 2
            getB = b_liq_S.get(0)

            if st_B == getB.bx.get_left()
                getB.bx.set_top(math.avg(minP, maxP) + (atr / liqMar))
                getB.bx.set_rightbottom(bar.index + 10, math.avg(minP, maxP) - (atr / liqMar))
            else
                b_liq_S.unshift(
                 liq.new(
                   box.new(st_B, math.avg(minP, maxP) + (atr / liqMar), bar.index + 10, math.avg(minP, maxP) - (atr / liqMar), bgcolor=color(na), border_color=color(na)),
                   box.new(na, na, na, na, bgcolor=color(na), border_color=color(na)),
                   label.new(st_B, st_P, 'Sellside liquidity', xloc = xloc.bar_index, yloc = yloc.price, style = label.style_none, textcolor = color.new(#f23645, 0), size = size.small),
                   false,
                   false,
                   line.new(st_B   , st_P, bar.index - 1, st_P, color = color.new(cLIQ_S, 0)),
                   line.new(bar.index - 1, st_P, na     , st_P, color = color.new(cLIQ_S, 0), style = line.style_dotted),
                   st_B)
                 )  

            if b_liq_S.size() > visLiq
                getLast = b_liq_S.pop()
                getLast.bx.delete()
                getLast.bxz.delete()
                label.delete(getLast.bxt)
                getLast.ln.delete()            
                getLast.lne.delete()               

liqHistMax = 490

for i = 0 to b_liq_B.size() - 1
    x = b_liq_B.get(i)

    if not x.brL and not na(x.anchorX) and bar_index - x.anchorX < liqHistMax
        x.lne.set_x2(bar.index)
        liqMidX = int(math.round((x.anchorX + bar.index) / 2))
        x.bxt.set_x(liqMidX)

        if bar.high > x.bx.get_top()
            x.brL := true

for i = 0 to b_liq_S.size() - 1
    x = b_liq_S.get(i)

    if not x.brL and not na(x.anchorX) and bar_index - x.anchorX < liqHistMax
        x.lne.set_x2(bar.index)
        liqMidX = int(math.round((x.anchorX + bar.index) / 2))
        x.bxt.set_x(liqMidX)

        if bar.low < x.bx.get_bottom()
            x.brL := true

// Swing-low SSL reclaim — same-bar hammer at swept liquidity + optional deferred pivot reclaim.
bullSweepCoreHit := false
bullSweepExcHit := false
bearSweepCoreHit := false
bearSweepExcHit := false

sweepBuf = revEarlyAtr * revEarlySweepBufferAtr

float sslTouch = na
float bslTouch = na
float sslReclaim = na
float bslReclaim = na
sslReach = revEarlyAtr * 0.08
for i = 0 to b_liq_S.size() - 1
    sslPx = b_liq_S.get(i).bx.get_bottom()
    sslAtLow = not na(sslPx) and sslPx <= low + sweepBuf and low <= sslPx + sweepBuf
    sslReclaimBar = not na(sslPx) and close > sslPx and low <= sslPx + sslReach and (low <= sslPx or close[1] <= sslPx)
    if sslAtLow
        sslTouch := na(sslTouch) ? sslPx : math.max(sslTouch, sslPx)
    if sslReclaimBar
        sslReclaim := na(sslReclaim) ? sslPx : math.max(sslReclaim, sslPx)
for i = 0 to b_liq_B.size() - 1
    bslPx = b_liq_B.get(i).bx.get_top()
    bslAtHigh = not na(bslPx) and bslPx >= high - sweepBuf and bslPx <= high + sweepBuf
    bslReclaimBar = not na(bslPx) and close < bslPx and high >= bslPx - sslReach and (high >= bslPx or close[1] >= bslPx)
    if bslAtHigh
        bslTouch := na(bslTouch) ? bslPx : math.min(bslTouch, bslPx)
    if bslReclaimBar
        bslReclaim := na(bslReclaim) ? bslPx : math.min(bslReclaim, bslPx)
stLowPx = stLow.lastPrice > 0 ? stLow.lastPrice : na
stHighPx = stHigh.lastPrice > 0 ? stHigh.lastPrice : na
if na(sslTouch) and not na(stLowPx) and stLowPx <= low + sweepBuf and low <= stLowPx + sweepBuf
    sslTouch := stLowPx
if na(bslTouch) and not na(stHighPx) and stHighPx >= high - sweepBuf and stHighPx <= high + sweepBuf
    bslTouch := stHighPx
if na(sslTouch) and not na(sessAsiaSsl) and (inLondonSess or inNySess) and sessAsiaSsl <= low + sweepBuf and low <= sessAsiaSsl + sweepBuf
    sslTouch := sessAsiaSsl
if na(bslTouch) and not na(sessAsiaBsl) and (inLondonSess or inNySess) and sessAsiaBsl >= high - sweepBuf and sessAsiaBsl <= high + sweepBuf
    bslTouch := sessAsiaBsl
if na(sslReclaim) and not na(stLowPx) and close > stLowPx and low <= stLowPx + sslReach and (low <= stLowPx or close[1] <= stLowPx)
    sslReclaim := stLowPx
if na(bslReclaim) and not na(stHighPx) and close < stHighPx and high >= stHighPx - sslReach and (high >= stHighPx or close[1] >= stHighPx)
    bslReclaim := stHighPx
if na(sslReclaim) and not na(sessAsiaSsl) and close > sessAsiaSsl and low <= sessAsiaSsl + sslReach and (low <= sessAsiaSsl or close[1] <= sessAsiaSsl)
    sslReclaim := sessAsiaSsl
if na(bslReclaim) and not na(sessAsiaBsl) and close < sessAsiaBsl and high >= sessAsiaBsl - sslReach and (high >= sessAsiaBsl or close[1] >= sessAsiaBsl)
    bslReclaim := sessAsiaBsl

bullPivotLow = low[1] <= low[2] and low[1] <= low[0]
bearPivotHigh = high[1] >= high[2] and high[1] >= high[0]
if bullPivotLow
    bullSwingBar := bar.index - 1
    bullSwingPrice := low[1]
    bullSwingSsl := sslTouch
    if na(bullSwingSsl)
        for i = 0 to b_liq_S.size() - 1
            sslPx = b_liq_S.get(i).bx.get_bottom()
            sslAtPivot = not na(sslPx) and sslPx <= low[1] + sweepBuf and low[1] <= sslPx + sweepBuf
            if sslAtPivot
                bullSwingSsl := na(bullSwingSsl) ? sslPx : math.max(bullSwingSsl, sslPx)
        if na(bullSwingSsl) and not na(stLowPx) and stLowPx <= low[1] + sweepBuf and low[1] <= stLowPx + sweepBuf
            bullSwingSsl := stLowPx
        if na(bullSwingSsl) and not na(sessAsiaSsl) and sessAsiaSsl <= low[1] + sweepBuf and low[1] <= sessAsiaSsl + sweepBuf
            bullSwingSsl := sessAsiaSsl
if bearPivotHigh
    bearSwingBar := bar.index - 1
    bearSwingPrice := high[1]
    bearSwingBsl := bslTouch
    if na(bearSwingBsl)
        for i = 0 to b_liq_B.size() - 1
            bslPx = b_liq_B.get(i).bx.get_top()
            bslAtPivot = not na(bslPx) and bslPx >= high[1] - sweepBuf and bslPx <= high[1] + sweepBuf
            if bslAtPivot
                bearSwingBsl := na(bearSwingBsl) ? bslPx : math.min(bearSwingBsl, bslPx)
        if na(bearSwingBsl) and not na(stHighPx) and stHighPx >= high[1] - sweepBuf and stHighPx <= high[1] + sweepBuf
            bearSwingBsl := stHighPx
        if na(bearSwingBsl) and not na(sessAsiaBsl) and sessAsiaBsl >= high[1] - sweepBuf and sessAsiaBsl <= high[1] + sweepBuf
            bearSwingBsl := sessAsiaBsl

bullSwingAge = not na(bullSwingBar) ? bar.index - bullSwingBar : na
bearSwingAge = not na(bearSwingBar) ? bar.index - bearSwingBar : na
bullRecentSwing = not na(bullSwingAge) and bullSwingAge >= 1 and bullSwingAge <= revEarlySwingLookback
bearRecentSwing = not na(bearSwingAge) and bearSwingAge >= 1 and bearSwingAge <= revEarlySwingLookback
bullReclaimSsl = not na(bullSwingSsl) ? bullSwingSsl : sslTouch
bearReclaimBsl = not na(bearSwingBsl) ? bearSwingBsl : bslTouch
bullAtSslZone = (not na(sslTouch) and low <= sslTouch + sweepBuf) or not na(sslReclaim) or bullAsiaEdgeZone
bearAtBslZone = (not na(bslTouch) and high >= bslTouch - sweepBuf) or not na(bslReclaim) or bearAsiaEdgeZone
bullSweepZoneOk = not revEarlySweepRequireZone or bullZoneContextOk or bullNearZone or bullAtSslZone
bearSweepZoneOk = not revEarlySweepRequireZone or bearZoneContextOk or bearNearZone or bearAtBslZone
bullDumpBlock = revEarlyTrendType == -1 and stMS.type == -1 and not bullAtSslZone
bearRipBlock = revEarlyTrendType == 1 and stMS.type == 1 and not bearAtBslZone
if sessPlaybookBear and (inLondonSess or inNySess)
    bullDumpBlock := bullDumpBlock or (not bullAtSslZone and not bullAsiaEdgeZone)
if sessPlaybookBull and (inLondonSess or inNySess)
    bearRipBlock := bearRipBlock or (not bearAtBslZone and not bearAsiaEdgeZone)
bullSweepCooldownOk = revEarlySweepCooldownBars <= 0 or na(bullSweepLastBar) or bar.index - bullSweepLastBar > revEarlySweepCooldownBars
bearSweepCooldownOk = revEarlySweepCooldownBars <= 0 or na(bearSweepLastBar) or bar.index - bearSweepLastBar > revEarlySweepCooldownBars

bullWickDom = not na(sslReclaim) and (close - low) > math.max(math.abs(close - open), revEarlyAtr * 0.04)
bearWickDom = not na(bslReclaim) and (high - close) > math.max(math.abs(close - open), revEarlyAtr * 0.04)
bullPopLen = math.max(nz(bullSwingAge, 1), 1)
bearPopLen = math.max(nz(bearSwingAge, 1), 1)
bullPopHigh = ta.highest(high[1], bullPopLen)
bearPopLow = ta.lowest(low[1], bearPopLen)
bullDispOk = not revEarlySweepRequireDisp or close > high[1] or bullWickDom or (bullRecentSwing and close > bullPopHigh)
bearDispOk = not revEarlySweepRequireDisp or close < low[1] or bearWickDom or (bearRecentSwing and close < bearPopLow)
bullSwingBodyOk = revEarlyAtr > 0 and (revEarlyBodyAtrRatio >= revEarlySwingMinBodyAtr or bullWickDom or (bullDispOk and revEarlyBodyAtrRatio >= revEarlyMinBodyAtr * 0.75))
bearSwingBodyOk = revEarlyAtr > 0 and (revEarlyBodyAtrRatio >= revEarlySwingMinBodyAtr or bearWickDom or (bearDispOk and revEarlyBodyAtrRatio >= revEarlyMinBodyAtr * 0.75))

bullLocalLow = low <= low[1] and low <= low[2]
bearLocalHigh = high >= high[1] and high >= high[2]
bullSslFresh = not na(sslReclaim) and close > sslReclaim and (low <= sslReclaim + sweepBuf or close[1] <= sslReclaim or low[1] <= sslReclaim + sweepBuf)
bearBslFresh = not na(bslReclaim) and close < bslReclaim and (high >= bslReclaim - sweepBuf or close[1] >= bslReclaim or high[1] >= bslReclaim - sweepBuf)
asiaLowWickDom = not na(sessAsiaSsl) and (close - low) > math.max(math.abs(close - open), revEarlyAtr * 0.04)
asiaHighWickDom = not na(sessAsiaBsl) and (high - close) > math.max(math.abs(close - open), revEarlyAtr * 0.04)
asiaLowHammer = sessPlaybookBear and not na(sessAsiaSsl) and low <= sessAsiaSsl + sweepBuf and close > sessAsiaSsl and asiaLowWickDom
asiaHighHammer = sessPlaybookBull and not na(sessAsiaBsl) and high >= sessAsiaBsl - sweepBuf and close < sessAsiaBsl and asiaHighWickDom

bullInstantRaw = bullSslFresh and bullLocalLow and (close > open or bullWickDom) and bullWickDom and bullSwingBodyOk
bearInstantRaw = bearBslFresh and bearLocalHigh and (close < open or bearWickDom) and bearWickDom and bearSwingBodyOk
bullInstantRaw := bullInstantRaw or (asiaLowHammer and bullLocalLow and bullSwingBodyOk and (inLondonSess or inNySess))
bearInstantRaw := bearInstantRaw or (asiaHighHammer and bearLocalHigh and bearSwingBodyOk and (inLondonSess or inNySess))
bullInstantSsl = bullInstantRaw and not bullInstantRaw[1] and not bullInstantRaw[2]
bearInstantBsl = bearInstantRaw and not bearInstantRaw[1] and not bearInstantRaw[2]
bullDeferReclaim = bullRecentSwing and not na(bullReclaimSsl) and close > bullReclaimSsl and close > open and bullDispOk and bullSwingBodyOk
bearDeferReclaim = bearRecentSwing and not na(bearReclaimBsl) and close < bearReclaimBsl and close < open and bearDispOk and bearSwingBodyOk
bullSwingReclaim = bullInstantSsl or bullDeferReclaim
bearSwingReclaim = bearInstantBsl or bearDeferReclaim

if revEarlySweepShow and revEarlyShow and bullSwingReclaim and bullSweepZoneOk and not bullDumpBlock and bullSweepCooldownOk
    if bullInstantSsl or not bullEarlyCoreBase
        if revEarlyContinuation and revEarlyTrendType == -1
            bullSweepExcHit := true
        else if revEarlyContinuation and revEarlyTrendType == 1
            bullSweepCoreHit := true
        else if bullInstantSsl
            bullSweepExcHit := true

if revEarlySweepShow and revEarlyShow and bearSwingReclaim and bearSweepZoneOk and not bearRipBlock and bearSweepCooldownOk
    if bearInstantBsl or not bearEarlyCoreBase
        if revEarlyContinuation and revEarlyTrendType == 1
            bearSweepExcHit := true
        else if revEarlyContinuation and revEarlyTrendType == -1
            bearSweepCoreHit := true
        else if bearInstantBsl
            bearSweepExcHit := true

bullPostSweepCoreBlock = not na(bullSweepLastBar) and bar.index > bullSweepLastBar and bar.index - bullSweepLastBar <= math.max(revEarlySwingLookback, revEarlySweepCooldownBars)
bearPostSweepCoreBlock = not na(bearSweepLastBar) and bar.index > bearSweepLastBar and bar.index - bearSweepLastBar <= math.max(revEarlySwingLookback, revEarlySweepCooldownBars)

bullExceptionFinal := bullExceptionBase or bullSweepExcHit
bearExceptionFinal := bearExceptionBase or bearSweepExcHit
bullEarlyCoreFinal := bullSweepCoreHit or (bullEarlyCoreBase and not bullPostSweepCoreBlock)
bearEarlyCoreFinal := bearSweepCoreHit or (bearEarlyCoreBase and not bearPostSweepCoreBlock)

bullExceptionPlot = switch revEarlyCounterTrendT
    'Allow All' => revEarlyExceptionShow ? bullExceptionFinal : bullSweepExcHit
    'Sweep Only' => bullSweepExcHit
    => false
bearExceptionPlot = switch revEarlyCounterTrendT
    'Allow All' => revEarlyExceptionShow ? bearExceptionFinal : bearSweepExcHit
    'Sweep Only' => bearSweepExcHit
    => false

bullEarlyStruct := bullEarlyCoreFinal or bullExceptionPlot
bearEarlyStruct := bearEarlyCoreFinal or bearExceptionPlot

barsSinceBullPlot = na(revEarlyLastBullPlotBar) ? 10000 : bar.index - revEarlyLastBullPlotBar
barsSinceBearPlot = na(revEarlyLastBearPlotBar) ? 10000 : bar.index - revEarlyLastBearPlotBar
revEarlyChop = revEarlyTrendType != 0 and stMS.type != 0 and revEarlyTrendType != stMS.type
bullClusterOk = revEarlyClusterBars <= 0 or barsSinceBullPlot > revEarlyClusterBars
bearClusterOk = revEarlyClusterBars <= 0 or barsSinceBearPlot > revEarlyClusterBars
bullPingPongOk = not revEarlyChop or revEarlyPingPongBars <= 0 or barsSinceBearPlot > revEarlyPingPongBars
bearPingPongOk = not revEarlyChop or revEarlyPingPongBars <= 0 or barsSinceBullPlot > revEarlyPingPongBars

revEarlyDirType = switch revEarlyDirectionSource
    'Macro' => revEarlyTrendType
    'Trigger' => revEarlyTriggerType
    'Macro + Micro' => revEarlyTrendType == 1 and stMS.type == 1 ? 1 : revEarlyTrendType == -1 and stMS.type == -1 ? -1 : 0
    => stMS.type
bullDirectionOk = not revEarlyAlignDirection or revEarlyDirType == 1
bearDirectionOk = not revEarlyAlignDirection or revEarlyDirType == -1

sessAllowBull = true
sessAllowBear = true
if sessEnable and sessFilterEarlyT == 'Hide Counter-Playbook'
    sessAllowBull := bullInstantSsl or bullSweepExcHit or not sessPlaybookBear
    sessAllowBear := bearInstantBsl or bearSweepExcHit or not sessPlaybookBull
else if sessEnable and sessFilterEarlyT == 'Playbook Only'
    sessAllowBull := bullInstantSsl or sessPlaybookBull
    sessAllowBear := bearInstantBsl or sessPlaybookBear

bullEarly := bullEarlyStruct and bullClusterOk and bullPingPongOk and bullDirectionOk and sessAllowBull
bearEarly := bearEarlyStruct and bearClusterOk and bearPingPongOk and bearDirectionOk and sessAllowBear

if bullEarlyCoreFinal
    bullEarlyLastBar := bar.index
    bullFlipSignaled := bullFlipBar
if bearEarlyCoreFinal
    bearEarlyLastBar := bar.index
    bearFlipSignaled := bearFlipBar
if bullExceptionPlot
    bullExceptionLastBar := bar.index
if bearExceptionPlot
    bearExceptionLastBar := bar.index
if bullSweepCoreHit or bullSweepExcHit
    bullSweepLastBar := bar.index
if bearSweepCoreHit or bearSweepExcHit
    bearSweepLastBar := bar.index
if bullEarly
    revEarlyLastBullPlotBar := bar.index
if bearEarly
    revEarlyLastBearPlotBar := bar.index

if revTrackShow
    i = 0
    while i < array.size(revPendDir)
        pendDir = array.get(revPendDir, i)
        tp = array.get(revPendTp, i)
        sl = array.get(revPendSl, i)
        born = array.get(revPendBorn, i)
        expiry = array.get(revPendExpiry, i)
        mode = array.get(revPendMode, i)

        if bar.index <= born
            i += 1
        else
            hitTp = pendDir == 1 ? high >= tp : low <= tp
            hitSl = pendDir == 1 ? low <= sl : high >= sl
            timedOut = bar.index >= expiry
            resolved = false

            if hitTp and not hitSl
                if pendDir == 1
                    revBullWin += 1
                else
                    revBearWin += 1
                if mode == 0
                    revCoreWin += 1
                else
                    revExceptionWin += 1
                resolved := true
            else if hitSl or (hitTp and hitSl)
                if pendDir == 1
                    revBullFalse += 1
                else
                    revBearFalse += 1
                if mode == 0
                    revCoreFalse += 1
                else
                    revExceptionFalse += 1
                resolved := true
            else if timedOut
                if pendDir == 1
                    revBullTimeout += 1
                else
                    revBearTimeout += 1
                if mode == 0
                    revCoreTimeout += 1
                else
                    revExceptionTimeout += 1
                resolved := true

            if resolved
                array.remove(revPendDir, i)
                array.remove(revPendEntry, i)
                array.remove(revPendTp, i)
                array.remove(revPendSl, i)
                array.remove(revPendBorn, i)
                array.remove(revPendExpiry, i)
                array.remove(revPendMode, i)
            else
                i += 1

    if bullEarly and revEarlyAtr > 0
        mode = bullEarlyCoreFinal ? 0 : 1
        entry = close
        target = entry + revEarlyAtr * revTrackAtrTarget
        stop = entry - revEarlyAtr * revTrackAtrTarget
        array.push(revPendDir, 1)
        array.push(revPendEntry, entry)
        array.push(revPendTp, target)
        array.push(revPendSl, stop)
        array.push(revPendBorn, bar.index)
        array.push(revPendExpiry, bar.index + revTrackLookaheadBars)
        array.push(revPendMode, mode)
        revBullTotal += 1
        if mode == 0
            revBullCoreTotal += 1
        else
            revBullExceptionTotal += 1

    if bearEarly and revEarlyAtr > 0
        mode = bearEarlyCoreFinal ? 0 : 1
        entry = close
        target = entry - revEarlyAtr * revTrackAtrTarget
        stop = entry + revEarlyAtr * revTrackAtrTarget
        array.push(revPendDir, -1)
        array.push(revPendEntry, entry)
        array.push(revPendTp, target)
        array.push(revPendSl, stop)
        array.push(revPendBorn, bar.index)
        array.push(revPendExpiry, bar.index + revTrackLookaheadBars)
        array.push(revPendMode, mode)
        revBearTotal += 1
        if mode == 0
            revBearCoreTotal += 1
        else
            revBearExceptionTotal += 1

revTiny = revMarkerSizeT == 'Tiny'
revSmall = revMarkerSizeT == 'Small'
revNormal = revMarkerSizeT == 'Normal'
revLarge = revMarkerSizeT == 'Large'

plotshape(bullEarly, title = 'Bullish Early Reversal Warning', style = shape.triangleup, location = location.belowbar, color = color.new(revBullColor, 0), size = size.tiny, text = '')
plotshape(bearEarly, title = 'Bearish Early Reversal Warning', style = shape.triangledown, location = location.abovebar, color = color.new(revBearColor, 0), size = size.tiny, text = '')

plotshape(bullReversal and revTiny, title = 'Bullish Reversal Marker Tiny', style = shape.circle, location = location.belowbar, color = revBullColor, size = size.tiny, text = 'REV')
plotshape(bullReversal and revSmall, title = 'Bullish Reversal Marker Small', style = shape.circle, location = location.belowbar, color = revBullColor, size = size.small, text = 'REV')
plotshape(bullReversal and revNormal, title = 'Bullish Reversal Marker Normal', style = shape.circle, location = location.belowbar, color = revBullColor, size = size.normal, text = 'REV')
plotshape(bullReversal and revLarge, title = 'Bullish Reversal Marker Large', style = shape.circle, location = location.belowbar, color = revBullColor, size = size.large, text = 'REV')

plotshape(bearReversal and revTiny, title = 'Bearish Reversal Marker Tiny', style = shape.circle, location = location.abovebar, color = revBearColor, size = size.tiny, text = 'REV')
plotshape(bearReversal and revSmall, title = 'Bearish Reversal Marker Small', style = shape.circle, location = location.abovebar, color = revBearColor, size = size.small, text = 'REV')
plotshape(bearReversal and revNormal, title = 'Bearish Reversal Marker Normal', style = shape.circle, location = location.abovebar, color = revBearColor, size = size.normal, text = 'REV')
plotshape(bearReversal and revLarge, title = 'Bearish Reversal Marker Large', style = shape.circle, location = location.abovebar, color = revBearColor, size = size.large, text = 'REV')

alertcondition(bullEarly, title = 'Bullish Early Reversal Warning', message = 'LUX-PA-v2: Early bullish reversal warning')
alertcondition(bearEarly, title = 'Bearish Early Reversal Warning', message = 'LUX-PA-v2: Early bearish reversal warning')
alertcondition(bullReversal, title = 'Bullish Confirmed Reversal', message = 'LUX-PA-v2: Confirmed bullish long-term reversal')
alertcondition(bearReversal, title = 'Bearish Confirmed Reversal', message = 'LUX-PA-v2: Confirmed bearish long-term reversal')
alertcondition(sessPlaybookBear and sessBreakSide == -1 and sessBreakSide[1] != -1, title = 'Bear Playbook Active', message = 'LUX-PA-v2: Tight Asia coil + London break LOW — bear playbook')
alertcondition(sessPlaybookBull and sessBreakSide == 1 and sessBreakSide[1] != 1, title = 'Bull Playbook Active', message = 'LUX-PA-v2: Tight Asia coil + London break HIGH — bull playbook')

// Persist previous structure states for next bar comparisons.
stTypePrev := stMS.type
itTypePrev := itMS.type
ltTypePrev := ltMS.type
mcTypePrev := mcMS.type

//---------------------------------------------------------------------------------------------------------------------}
// Calculations - Liquidity Voids 
//---------------------------------------------------------------------------------------------------------------------{

atr200  = ta.atr(200) * lqThresh
dispPeriod = lqMode == 'Present' ? last_bar_index - bar_index <=  lqPeriod : true

if lqVoid and dispPeriod and bar_index >= 2
    bull = bar.low - (bar[2]).high > atr200 and bar.low > (bar[2]).high and (bar[1]).close > (bar[2]).high
    bear = (bar[2]).low - bar.high > atr200 and bar.high < (bar[2]).low and (bar[1]).close < (bar[2]).low
    lqVoidBullAlign = sessNyExpansion and sessBreakSide == 1
    lqVoidBearAlign = sessNyExpansion and sessBreakSide == -1

    if bull 
        l  = 13
        if not bull[1]
            st = math.abs(bar.low - (bar[2]).high) / l
            voidBg = lqVoidBullAlign ? color.new(#089981, 55) : cLQV_B
            for i = 0 to l - 1
                if lqText and i == 0
                    array.push(b_liq_V, box.new(bar.index - 2, (bar[2]).high + i * st, bar.index, (bar[2]).high + (i + 1) * st, text = lqVoidBullAlign ? 'Void · NY Exp' : 'Liquidity Void   ', text_size = size.small, text_halign = text.align_center, text_valign = text.align_bottom, text_color = color.new(#089981, 0), border_color = na, bgcolor = voidBg ))
                else
                    array.push(b_liq_V, box.new(bar.index - 2, (bar[2]).high + i * st, bar.index, (bar[2]).high + (i + 1) * st, border_color = na, bgcolor = voidBg ))

    if bear
        l  = 13
        if not bear[1]
            st = math.abs((bar[2]).low - bar.high) / l
            voidBg = lqVoidBearAlign ? color.new(#f23645, 55) : cLQV_S
            for i = 0 to l - 1
                if lqText and i == l - 1
                    array.push(b_liq_V, box.new(bar.index - 2, bar.high + i * st, bar.index, bar.high + (i + 1) * st, text = lqVoidBearAlign ? 'Void · NY Exp' : 'Liquidity Void   ', text_size = size.small, text_halign = text.align_center, text_valign = text.align_top, text_color = color.new(#f23645, 0), border_color = na, bgcolor = voidBg ))
                else
                    array.push(b_liq_V, box.new(bar.index - 2, bar.high + i * st, bar.index, bar.high + (i + 1) * st, border_color = na, bgcolor = voidBg ))

if b_liq_V.size() > 0 and bar_index >= 1
    qt = b_liq_V.size()
    for bn = qt - 1 to 0
        if bn < b_liq_V.size()
            cb = b_liq_V.get(bn)
            ba = math.avg(cb.get_bottom(), cb.get_top())

            if math.sign((bar[1]).close - ba) != math.sign(bar.close - ba) or math.sign((bar[1]).close - ba) != math.sign(bar.low - ba) or math.sign((bar[1]).close - ba) != math.sign(bar.high - ba)
                cb.delete()
                b_liq_V.remove(bn)
            else
                cb.set_right(bar.index + 1)

                // Keep bullish/bearish text coloring persistent.


//---------------------------------------------------------------------------------------------------------------------}
// Order & Breaker Blocks
//---------------------------------------------------------------------------------------------------------------------{

depth  = switch obbTerm
    'Micro' => 1
    'Short Term' => 1
    'Intermediate Term' => 2
    'Long Term' => 3
    'Macro' => 4

var fractalHigh = array.new<vector>(0)
var fractalLow = array.new<vector>(0)

if barstate.isfirst
    for i = 0 to depth - 1
        fractalHigh.push(vector.new(array.new<SWING>(0)))
        fractalLow.push(vector.new(array.new<SWING>(0)))

fractalHigh.get(0).v.unshift(SWING.new(bar.high, bar.index))
fractalLow.get(0).v.unshift(SWING.new(bar.low, bar.index))

if fractalHigh.get(0).v.size() > 3
    fractalHigh.get(0).v.pop()

if fractalLow.get(0).v.size() > 3
    fractalLow.get(0).v.pop()

top = fractalHigh.detectSwings('bull', depth)
btm = fractalLow.detectSwings('bear', depth)


if obbShow

    max = obbUseBody ? math.max(bar.close, bar.open) : bar.high
    min = obbUseBody ? math.min(bar.close, bar.open) : bar.low

    if bar.close > top.y and not top.crossed
        top.crossed := true

        minima = max[1]
        maxima = min[1]
        loc = time[1]

        for i = 1 to (bar.index - top.x) - 1
            minima := math.min(min[i], minima)
            maxima := minima == min[i] ? max[i] : maxima
            loc := minima == min[i] ? time[i] : loc

        bullish_ob.unshift(ob.new(maxima, minima, loc))

    if bullish_ob.size() > 100//obbBullLast
        bullish_ob.pop() 

    if bullish_ob.size() > 0
        for i = bullish_ob.size() - 1 to 0
            element = bullish_ob.get(i)

            if not element.breaker 
                if math.min(bar.close, bar.open) < element.btm
                    element.breaker := true
                    element.break_loc := time
            else
                if bar.close > element.top
                    bullish_ob.remove(i)

    if bar.close < btm.y and not btm.crossed
        btm.crossed := true

        minima = min[1]
        maxima = max[1]
        loc = time[1]

        for i = 1 to (bar.index - btm.x) - 1
            maxima := math.max(max[i], maxima)
            minima := maxima == max[i] ? min[i] : minima
            loc := maxima == max[i] ? time[i] : loc

        bearish_ob.unshift(ob.new(maxima, minima, loc))

    if bearish_ob.size() > 100//obbBearLast
        bearish_ob.pop() 

    if bearish_ob.size() > 0
        for i = bearish_ob.size() - 1 to 0
            element = bearish_ob.get(i)

            if not element.breaker 
                if math.max(bar.close, bar.open) > element.top
                    element.breaker := true
                    element.break_loc := time
            else
                if bar.close < element.btm
                    bearish_ob.remove(i)

    if bxOBB.size() > 0
        for i = 0 to bxOBB.size() - 1
            box.delete(bxOBB.shift())

    if lnOBB.size() > 0
        for i = 0 to lnOBB.size() - 1
            line.delete(lnOBB.shift())

    if barstate.islast
        if obbBullLast > 0 and bullish_ob.size() > 0
            for i = 0 to math.min(obbBullLast - 1, bullish_ob.size() - 1)
                get_ob = bullish_ob.get(i)
                get_ob.renderBlocks(obbBullColor, obbBullBreakColor, 'Bullish BB', color.new(#089981, 0))

        if obbBearLast > 0 and bearish_ob.size() > 0
            for i = 0 to math.min(obbBearLast - 1, bearish_ob.size() - 1)
                get_ob = bearish_ob.get(i)
                get_ob.renderBlocks(obbBearColor, obbBearBreakColor, 'Bearish BB', color.new(#f23645, 0))

//---------------------------------------------------------------------------------------------------------------------}
// Dashboard
//---------------------------------------------------------------------------------------------------------------------{

microStr = stMS.type == 1 ? 'Bullish' : stMS.type == -1 ? 'Bearish' : 'Neutral'
microCol = stMS.type == 1 ? color.new(#089981, 0) : stMS.type == -1 ? color.new(#f23645, 0) : color.silver

macroStr = mcMS.type == 1 ? 'Bullish' : mcMS.type == -1 ? 'Bearish' : 'Neutral'
macroCol = mcMS.type == 1 ? color.new(#089981, 0) : mcMS.type == -1 ? color.new(#f23645, 0) : color.silver

zoneStr = 'Neutral'
zoneCol = color.silver

if obbShow
    inBullZone = false
    inBearZone = false

    if bullish_ob.size() > 0
        for i = 0 to bullish_ob.size() - 1
            z = bullish_ob.get(i)
            if close <= z.top and close >= z.btm
                inBullZone := true
                break

    if bearish_ob.size() > 0
        for i = 0 to bearish_ob.size() - 1
            z = bearish_ob.get(i)
            if close <= z.top and close >= z.btm
                inBearZone := true
                break

    if inBullZone and not inBearZone
        zoneStr := bullAsiaEdgeZone ? 'Bull BB · Asia L' : 'Bullish BB Zone'
        zoneCol := color.new(#089981, 0)
    else if inBearZone and not inBullZone
        zoneStr := bearAsiaEdgeZone ? 'Bear BB · Asia H' : 'Bearish BB Zone'
        zoneCol := color.new(#f23645, 0)
    else if inBullZone and inBearZone
        zoneStr := 'Mixed BB Zone'
        zoneCol := color.orange
    else if bullAsiaEdgeZone
        zoneStr := 'Asia Low Edge'
        zoneCol := color.new(#089981, 0)
    else if bearAsiaEdgeZone
        zoneStr := 'Asia High Edge'
        zoneCol := color.new(#f23645, 0)
else
    zoneStr := 'OBB Off'

float nearestBsl = na
float nearestSsl = na

for i = 0 to b_liq_B.size() - 1
    lv = b_liq_B.get(i)
    if not lv.brL
        p = lv.bx.get_top()
        if p > close
            nearestBsl := na(nearestBsl) ? p : math.min(nearestBsl, p)

for i = 0 to b_liq_S.size() - 1
    lv = b_liq_S.get(i)
    if not lv.brL
        p = lv.bx.get_bottom()
        if p < close
            nearestSsl := na(nearestSsl) ? p : math.max(nearestSsl, p)

if sessPlaybookBull and not na(sessAsiaBsl) and sessAsiaBsl > close
    nearestBsl := na(nearestBsl) ? sessAsiaBsl : math.min(nearestBsl, sessAsiaBsl)
if sessPlaybookBear and not na(sessAsiaSsl) and sessAsiaSsl < close
    nearestSsl := na(nearestSsl) ? sessAsiaSsl : math.max(nearestSsl, sessAsiaSsl)

targetStr = 'N/A'
targetCol = color.silver

allowBullTarget = stMS.type == 1 and (not dashTargetConfluence or mcMS.type == 1)
allowBearTarget = stMS.type == -1 and (not dashTargetConfluence or mcMS.type == -1)

if allowBullTarget and not na(nearestBsl)
    targetStr := 'BSL ' + str.tostring(nearestBsl, format.mintick)
    targetCol := color.new(#089981, 0)
else if allowBearTarget and not na(nearestSsl)
    targetStr := 'SSL ' + str.tostring(nearestSsl, format.mintick)
    targetCol := color.new(#f23645, 0)
else
    if not na(nearestBsl) and not na(nearestSsl)
        targetStr := 'BSL ' + str.tostring(nearestBsl, format.mintick) + ' / SSL ' + str.tostring(nearestSsl, format.mintick)
    else if not na(nearestBsl)
        targetStr := 'BSL ' + str.tostring(nearestBsl, format.mintick)
    else if not na(nearestSsl)
        targetStr := 'SSL ' + str.tostring(nearestSsl, format.mintick)

sessPhaseStr = not sessEnable ? 'Off' : inAsiaSess ? 'Asia' : inLondonSess ? 'London' : inNySess ? 'NY' : 'Late'
sessPhaseCol = inAsiaSess ? color.new(color.blue, 0) : inLondonSess ? color.new(color.orange, 0) : inNySess ? color.new(color.purple, 0) : color.silver
sessCoilTag = sessCoilTightUsd and sessCoilTightAtr ? ' · $+ATR' : sessCoilTightAtr and not sessCoilTightUsd ? ' · ATR' : ''
sessCoilStr = not sessEnable or na(sessAsiaRange) ? 'N/A' : sessCoilActive ? 'Tight $' + str.tostring(sessAsiaRange, '#') + sessCoilTag : 'Wide $' + str.tostring(sessAsiaRange, '#')
sessCoilCol = sessCoilActive ? color.new(color.lime, 0) : color.orange
sessPlayStr = not sessEnable ? 'Off' : sessPlaybookBear ? 'BEAR · Break Low' : sessPlaybookBull ? 'BULL · Break High' : sessCoilActive and inLondonSess ? 'COIL · Watch' : sessCoilActive ? 'COIL · Wait' : 'No Coil'
sessPlayCol = sessPlaybookBear ? color.new(#f23645, 0) : sessPlaybookBull ? color.new(#089981, 0) : sessCoilActive ? color.new(color.yellow, 0) : color.silver

if dashShow
    var table dash = table.new(dashPosition(dashPos), 2, 8, border_width = 1, frame_width = 1, frame_color = color.gray)
    table.clear(dash, 0, 0, 1, 7)
    table.cell(dash, 0, 0, 'Lux-PA', text_color = color.white, text_size = size.tiny, bgcolor = color.new(color.blue, 0))
    table.cell(dash, 1, 0, 'Sniper 7-Row', text_color = color.white, text_size = size.tiny, bgcolor = color.new(color.blue, 0))
    dashRow(dash, 1, 'MACRO', macroStr, macroCol)
    dashRow(dash, 2, 'MICRO MSS', microStr, microCol)
    dashRow(dash, 3, 'ZONE', zoneStr, zoneCol)
    dashRow(dash, 4, 'TARGET', targetStr, targetCol)
    dashRow(dash, 5, 'SESSION', sessPhaseStr, sessPhaseCol)
    dashRow(dash, 6, 'COIL', sessCoilStr, sessCoilCol)
    dashRow(dash, 7, 'PLAYBOOK', sessPlayStr, sessPlayCol)

bullPrecStr = ratioPctStr(revBullWin, revBullFalse)
bearPrecStr = ratioPctStr(revBearWin, revBearFalse)
allPrecStr = ratioPctStr(revBullWin + revBearWin, revBullFalse + revBearFalse)
corePrecStr = ratioPctStr(revCoreWin, revCoreFalse)
exceptionPrecStr = ratioPctStr(revExceptionWin, revExceptionFalse)
totalCore = revBullCoreTotal + revBearCoreTotal
totalException = revBullExceptionTotal + revBearExceptionTotal
totalTracked = revBullTotal + revBearTotal
pendingTracked = array.size(revPendDir)
coreTimeoutStr = str.tostring(revCoreTimeout)
exceptionTimeoutStr = str.tostring(revExceptionTimeout)

// Next Move scenario engine (probabilistic bias, not prediction).
nextMacroType = revEarlyTrendType
nextMicroType = stMS.type
nextChop = nextMacroType == 0 or nextMicroType == 0 or (nextMacroType != nextMicroType and not bullZoneContextOk and not bearZoneContextOk)
nextBearCont = nextMacroType == -1 and nextMicroType == -1
nextBullCont = nextMacroType == 1 and nextMicroType == 1
nextBullPull = nextMacroType == -1 and (nextMicroType == 1 or bullZoneContextOk)
nextBearPull = nextMacroType == 1 and (nextMicroType == -1 or bearZoneContextOk)

nextMoveStr = 'Range / Wait'
nextMoveCol = color.new(color.white, 0)
nextSourceStr = 'Structure'
nextConfNum = 50.0

if bullEarly
    nextMoveStr := bullSweepExcHit ? 'Bull Pullback' : bullSweepCoreHit ? 'Bull Continuation' : bullExceptionPlot ? 'Bull Pullback' : 'Bull Continuation'
    nextMoveCol := color.new(#089981, 0)
    nextSourceStr := bullSweepExcHit or bullSweepCoreHit ? 'Sweep' : bullExceptionPlot ? 'Exception' : 'Core'
else if bearEarly
    nextMoveStr := bearSweepExcHit ? 'Bear Pullback' : bearSweepCoreHit ? 'Bear Continuation' : bearExceptionPlot ? 'Bear Pullback' : 'Bear Continuation'
    nextMoveCol := color.new(#f23645, 0)
    nextSourceStr := bearSweepExcHit or bearSweepCoreHit ? 'Sweep' : bearExceptionPlot ? 'Exception' : 'Core'
else if nextChop
    nextMoveStr := 'Range / Wait'
    nextMoveCol := color.new(#ECEFF1, 0)
    nextSourceStr := 'Chop'
else if nextBearCont
    nextMoveStr := 'Bear Continuation'
    nextMoveCol := color.new(#f23645, 0)
    nextSourceStr := 'Core'
else if nextBullCont
    nextMoveStr := 'Bull Continuation'
    nextMoveCol := color.new(#089981, 0)
    nextSourceStr := 'Core'
else if nextBullPull
    nextMoveStr := 'Bull Pullback'
    nextMoveCol := color.new(#089981, 0)
    nextSourceStr := 'Exception'
else if nextBearPull
    nextMoveStr := 'Bear Pullback'
    nextMoveCol := color.new(#f23645, 0)
    nextSourceStr := 'Exception'
else if sessPlaybookBear and (inLondonSess or inNySess)
    nextMoveStr := 'Bear Continuation'
    nextMoveCol := color.new(#f23645, 0)
    nextSourceStr := 'Playbook'
else if sessPlaybookBull and (inLondonSess or inNySess)
    nextMoveStr := 'Bull Continuation'
    nextMoveCol := color.new(#089981, 0)
    nextSourceStr := 'Playbook'

coreResolved = revCoreWin + revCoreFalse
excResolved = revExceptionWin + revExceptionFalse
bullResolved = revBullWin + revBullFalse
bearResolved = revBearWin + revBearFalse
corePrecNum = coreResolved > 0 ? (revCoreWin * 100.0) / coreResolved : na
excPrecNum = excResolved > 0 ? (revExceptionWin * 100.0) / excResolved : na
bullPrecNum = bullResolved > 0 ? (revBullWin * 100.0) / bullResolved : na
bearPrecNum = bearResolved > 0 ? (revBearWin * 100.0) / bearResolved : na
allResolved = revBullWin + revBearWin + revBullFalse + revBearFalse
allPrecNum = allResolved > 0 ? ((revBullWin + revBearWin) * 100.0) / allResolved : na

if nextSourceStr == 'Core'
    if str.contains(nextMoveStr, 'Bull') and not na(bullPrecNum)
        nextConfNum := bullPrecNum
    else if str.contains(nextMoveStr, 'Bear') and not na(bearPrecNum)
        nextConfNum := bearPrecNum
    else if not na(corePrecNum)
        nextConfNum := corePrecNum
else if nextSourceStr == 'Exception' and not na(excPrecNum)
    nextConfNum := excPrecNum
else if nextSourceStr == 'Playbook' and sessConfBoost
    if sessPlaybookBear and not na(bearPrecNum)
        nextConfNum := math.min(100.0, bearPrecNum + sessBearConfAdd)
    else if sessPlaybookBull and not na(bullPrecNum)
        nextConfNum := math.min(100.0, bullPrecNum + sessBullConfAdd)
    else if sessPlaybookBear
        nextConfNum := 78.0
    else if sessPlaybookBull
        nextConfNum := 71.0
else if nextSourceStr == 'Chop'
    nextConfNum := 0
else if not na(allPrecNum)
    nextConfNum := allPrecNum

nextConfStr = str.tostring(nextConfNum, '#.0') + '%'
nextConfCol = nextConfNum >= nextMoveMinConf ? color.new(color.lime, 0) : nextConfNum >= 45 ? color.orange : color.new(#f23645, 0)

nextTargetStr = 'N/A'
nextTargetCol = color.new(color.white, 0)
nextInvalidStr = 'N/A'
nextInvalidCol = color.new(color.white, 0)
nextWindowStr = str.tostring(revTrackLookaheadBars) + ' bars'
nextMoveShort = 'RANGE'
if nextMoveStr == 'Bull Continuation'
    nextMoveShort := 'BULL CONT'
else if nextMoveStr == 'Bull Pullback'
    nextMoveShort := 'BULL PULL'
else if nextMoveStr == 'Bear Continuation'
    nextMoveShort := 'BEAR CONT'
else if nextMoveStr == 'Bear Pullback'
    nextMoveShort := 'BEAR PULL'
else if nextMoveStr == 'Range / Wait'
    nextMoveShort := 'RANGE'

if str.contains(nextMoveStr, 'Bull')
    nextTargetStr := not na(nearestBsl) ? 'BSL ' + str.tostring(nearestBsl, format.mintick) : targetStr
    nextTargetCol := color.new(#089981, 0)
    nextInvalidStr := not na(sessAsiaLow) and sessPlaybookBull ? str.tostring(sessAsiaLow, format.mintick) : not na(itLow.lastPrice) ? str.tostring(itLow.lastPrice, format.mintick) : str.tostring(ltLow.lastPrice, format.mintick)
    nextInvalidCol := color.new(#f23645, 0)
else if str.contains(nextMoveStr, 'Bear')
    nextTargetStr := not na(nearestSsl) ? 'SSL ' + str.tostring(nearestSsl, format.mintick) : targetStr
    nextTargetCol := color.new(#f23645, 0)
    nextInvalidStr := not na(sessAsiaHigh) and sessPlaybookBear ? str.tostring(sessAsiaHigh, format.mintick) : not na(itHigh.lastPrice) ? str.tostring(itHigh.lastPrice, format.mintick) : str.tostring(ltHigh.lastPrice, format.mintick)
    nextInvalidCol := color.new(#089981, 0)

if dashEarlyShow
    var table earlyDash = table.new(dashPosition(dashEarlyPos), 2, 11, border_width = 1, frame_width = 1, frame_color = color.gray)
    table.clear(earlyDash, 0, 0, 1, 10)
    table.cell(earlyDash, 0, 0, 'EARLY Track', text_color = color.white, text_size = size.tiny, bgcolor = color.new(color.purple, 0))
    table.cell(earlyDash, 1, 0, str.tostring(totalTracked), text_color = color.white, text_size = size.tiny, bgcolor = color.new(color.purple, 0))
    dashRow(earlyDash, 1, 'Precision', allPrecStr, color.new(color.white, 0))
    dashRow(earlyDash, 2, 'Bull Prec', bullPrecStr, color.new(#089981, 0))
    dashRow(earlyDash, 3, 'Bear Prec', bearPrecStr, color.new(#f23645, 0))
    dashRow(earlyDash, 4, 'Core/Exc', str.tostring(totalCore) + ' / ' + str.tostring(totalException), color.silver)
    dashRow(earlyDash, 5, 'Core Prec', corePrecStr, color.new(color.yellow, 0))
    dashRow(earlyDash, 6, 'Exc Prec', exceptionPrecStr, color.new(color.orange, 0))
    dashRow(earlyDash, 7, 'Wins', str.tostring(revBullWin + revBearWin), color.new(color.lime, 0))
    dashRow(earlyDash, 8, 'False', str.tostring(revBullFalse + revBearFalse), color.new(color.red, 0))
    dashRow(earlyDash, 9, 'TO C/E', coreTimeoutStr + ' / ' + exceptionTimeoutStr, color.orange)
    dashRow(earlyDash, 10, 'Pending', str.tostring(pendingTracked), color.new(color.aqua, 0))

if dashNextMoveShow
    var table nextDash = table.new(dashPosition(dashNextMovePos), 2, 8, border_width = 1, frame_width = 1, frame_color = color.gray)
    table.clear(nextDash, 0, 0, 1, 7)
    table.cell(nextDash, 0, 0, 'NEXT MOVE', text_color = color.white, text_size = size.tiny, bgcolor = color.new(color.teal, 0))
    table.cell(nextDash, 1, 0, nextMoveShort, text_color = nextMoveCol, text_size = size.tiny, bgcolor = color.new(color.black, 60))
    dashRow(nextDash, 1, 'CONF', nextConfStr, nextConfCol)
    dashRow(nextDash, 2, 'TARGET', nextTargetStr, nextTargetCol)
    dashRow(nextDash, 3, 'INVALID', nextInvalidStr, nextInvalidCol)
    dashRow(nextDash, 4, 'WINDOW', nextWindowStr, color.silver)
    dashRow(nextDash, 5, 'SOURCE', nextSourceStr, nextMoveCol)
    dashRow(nextDash, 6, 'COIL', sessCoilStr, sessCoilCol)
    dashRow(nextDash, 7, 'PLAYBOOK', sessPlayStr, sessPlayCol)

//---------------------------------------------------------------------------------------------------------------------}
//---------------------------------------------------------------------------------------------------------------------
// A+ SETUP TRIGGER  (added in v2) — gated entry signal with auto Entry / SL / TP
//---------------------------------------------------------------------------------------------------------------------{
// This block is READ-ONLY against existing logic: it consumes variables the script already
// computes (bullEarly, bearEarly, stMS, mcMS, zone flags, playbook flags, nearestBsl/Ssl,
// nextConfNum, revEarlyAtr) and never reassigns them. Safe to delete with no side effects.

trigGroup = 'A+ Setup Trigger'
trigShow        = input.bool(true,  'Show A+ Setup Trigger', group = trigGroup)
trigReqMacro    = input.bool(true,  '  Require Macro alignment',        group = trigGroup)
trigReqMicro    = input.bool(true,  '  Require Micro MSS alignment',    group = trigGroup)
trigReqPlaybook = input.bool(true,  '  Require Session Playbook align', group = trigGroup)
trigReqZone     = input.bool(true,  '  Require Zone context (BB/Edge)', group = trigGroup)
trigReqConf     = input.bool(true,  '  Require CONF >= threshold',      group = trigGroup)
trigMinConf     = input.float(52.0, '  CONF threshold (%)', minval = 0, maxval = 100, step = 1, group = trigGroup)
trigRR          = input.float(2.0,  '  Min Reward:Risk to plot',  minval = 0.1, step = 0.1, group = trigGroup, tooltip = 'Setup only plots if TP distance / SL distance is at least this. Set low to see all.')
trigSlAtrMult   = input.float(0.50, '  SL buffer beyond zone (ATR)', minval = 0, step = 0.05, group = trigGroup)
trigUsePoolTp   = input.bool(true,  '  TP = nearest liquidity pool',  group = trigGroup, tooltip = 'On: TP is nearest BSL/SSL. Off: TP = entry +/- (RR x risk).')
trigLabelSize   = input.string('Normal', '  Label Size', options = ['Tiny','Small','Normal','Large'], group = trigGroup)
trigBoxShow     = input.bool(true,  '  Draw Entry/SL/TP zones', group = trigGroup)
trigBullCol     = input.color(color.new(#089981, 0), '  Bull', inline = 'TC', group = trigGroup)
trigBearCol     = input.color(color.new(#f23645, 0), 'Bear',   inline = 'TC', group = trigGroup)

// --- gate conditions (each optional via toggle) ---
trigMacroBull = not trigReqMacro    or mcMS.type == 1
trigMacroBear = not trigReqMacro    or mcMS.type == -1
trigMicroBull = not trigReqMicro    or stMS.type == 1
trigMicroBear = not trigReqMicro    or stMS.type == -1
trigPlayBull  = not trigReqPlaybook or sessPlaybookBull or not sessEnable
trigPlayBear  = not trigReqPlaybook or sessPlaybookBear or not sessEnable
trigZoneBull  = not trigReqZone     or bullZoneContextOk
trigZoneBear  = not trigReqZone     or bearZoneContextOk
trigConfOk    = not trigReqConf     or nextConfNum >= trigMinConf

// --- raw A+ events: existing trigger + all enabled gates ---
trigBullRaw = trigShow and bullEarly and trigMacroBull and trigMicroBull and trigPlayBull and trigZoneBull and trigConfOk
trigBearRaw = trigShow and bearEarly and trigMacroBear and trigMicroBear and trigPlayBear and trigZoneBear and trigConfOk

// --- build Entry / SL / TP ---
trigAtr = revEarlyAtr
var float trigEntry = na
var float trigSl = na
var float trigTp = na

makeBullSetup() =>
    e  = close
    z  = bullZoneContextOk and not na(sessAsiaLow) ? math.min(low, sessAsiaLow) : low
    sl = z - trigAtr * trigSlAtrMult
    risk = e - sl
    tpPool = not na(nearestBsl) ? nearestBsl : na
    tp = trigUsePoolTp and not na(tpPool) ? tpPool : e + risk * trigRR
    [e, sl, tp, risk]

makeBearSetup() =>
    e  = close
    z  = bearZoneContextOk and not na(sessAsiaHigh) ? math.max(high, sessAsiaHigh) : high
    sl = z + trigAtr * trigSlAtrMult
    risk = sl - e
    tpPool = not na(nearestSsl) ? nearestSsl : na
    tp = trigUsePoolTp and not na(tpPool) ? tpPool : e - risk * trigRR
    [e, sl, tp, risk]

trigBull = false
trigBear = false
if trigBullRaw
    [e, sl, tp, risk] = makeBullSetup()
    rr = risk > 0 ? (tp - e) / risk : 0
    if rr >= trigRR and tp > e
        trigBull := true
        trigEntry := e
        trigSl := sl
        trigTp := tp
else if trigBearRaw
    [e, sl, tp, risk] = makeBearSetup()
    rr = risk > 0 ? (e - tp) / risk : 0
    if rr >= trigRR and tp < e
        trigBear := true
        trigEntry := e
        trigSl := sl
        trigTp := tp


// --- draw ---
trigLblSz = textSize(trigLabelSize)
if trigBull
    rr = (trigTp - trigEntry) / (trigEntry - trigSl)
    label.new(bar_index, trigSl, '▲ A+ LONG\nEntry ' + str.tostring(trigEntry, format.mintick) + '\nSL ' + str.tostring(trigSl, format.mintick) + '\nTP ' + str.tostring(trigTp, format.mintick) + '\nR:R ' + str.tostring(rr, '#.0'), style = label.style_label_up, color = trigBullCol, textcolor = color.white, size = trigLblSz)
    if trigBoxShow
        box.new(bar_index, trigTp, bar_index + 12, trigEntry, border_color = color.new(trigBullCol, 50), bgcolor = color.new(trigBullCol, 85))
        box.new(bar_index, trigEntry, bar_index + 12, trigSl, border_color = color.new(trigBearCol, 50), bgcolor = color.new(trigBearCol, 85))
        line.new(bar_index, trigEntry, bar_index + 12, trigEntry, color = color.white, style = line.style_dashed, width = 1)
if trigBear
    rr = (trigEntry - trigTp) / (trigSl - trigEntry)
    label.new(bar_index, trigSl, '▼ A+ SHORT\nEntry ' + str.tostring(trigEntry, format.mintick) + '\nSL ' + str.tostring(trigSl, format.mintick) + '\nTP ' + str.tostring(trigTp, format.mintick) + '\nR:R ' + str.tostring(rr, '#.0'), style = label.style_label_down, color = trigBearCol, textcolor = color.white, size = trigLblSz)
    if trigBoxShow
        box.new(bar_index, trigEntry, bar_index + 12, trigTp, border_color = color.new(trigBearCol, 50), bgcolor = color.new(trigBearCol, 85))
        box.new(bar_index, trigSl, bar_index + 12, trigEntry, border_color = color.new(trigBullCol, 50), bgcolor = color.new(trigBullCol, 85))
        line.new(bar_index, trigEntry, bar_index + 12, trigEntry, color = color.white, style = line.style_dashed, width = 1)

// --- alerts ---
alertcondition(trigBull, title = 'A+ Long Setup', message = 'LUX-PA-v2: A+ LONG — gated trigger fired. Entry/SL/TP on chart.')
alertcondition(trigBear, title = 'A+ Short Setup', message = 'LUX-PA-v2: A+ SHORT — gated trigger fired. Entry/SL/TP on chart.')

plotshape(trigBull, title = 'A+ Long', style = shape.triangleup,   location = location.belowbar, color = trigBullCol, size = size.small)
plotshape(trigBear, title = 'A+ Short', style = shape.triangledown, location = location.abovebar, color = trigBearCol, size = size.small)
//---------------------------------------------------------------------------------------------------------------------}
